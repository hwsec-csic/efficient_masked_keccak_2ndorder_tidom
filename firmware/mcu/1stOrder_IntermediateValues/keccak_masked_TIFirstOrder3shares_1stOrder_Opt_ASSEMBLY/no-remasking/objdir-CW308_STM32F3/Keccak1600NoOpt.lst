 1150              	    xorrol      r10, r3, r4
 1151              	    str         r10, [r0, #mDe0_s2]
 1152              	    xor5        r6,  Aba1_s2_M2, Aka0_s2_M2, Asa1_s2_M2, Aga1_s2_M2, Ama0_s2_M2
 1153              	    eors        r11, r6, r5
 1154              	    str         r11, [r0, #mDe1_s2]
 1155              	
 1156              	    xor5        r4,  Amo0_s2_M2, Abo1_s2_M2, Ako0_s2_M2, Aso1_s2_M2, Ago0_s2_M2
 1157              	    xorrol      r5, lr, r4
 1158              	    str         r5, [r0, #mDi0_s2]
 1159              	    xor5        r5,  Amo1_s2_M2, Abo0_s2_M2, Ako1_s2_M2, Aso0_s2_M2, Ago1_s2_M2
 1160              	    eors        r2, r7, r5
 1161              	    str         r2, [r0, #mDi1_s2]
 1162              	
 1163              	    xorrol      r12, r5, r6
 1164              	    str         r12, [r0, #mDu0_s2]
 1165              	    eors        lr, r4, r3
