 398              	
 399              	@----------------------------------------------------------------------------------
 400              	@-----------------------------------------XOR5 MACRO-------------------------------
 401              	@----------------------------------------------------------------------------------
 402              	@Used in theta step (at the beginning of each macro KeccakRound0, KeccakRound1, 
 403              	@KeccakRound2, KeccakRound3) to compute the parities C(x) of each column (considering
 404              	@a particular half and share). 
 405              	@
 406              	@It receives as inputs:
 407              	@   -i1, i2, i3, i4, i5: memory addresses where 32-bit lanes from the same column, half, and share
 408              	@                        are stored in the INPUT SPACE
 409              	@   -res: register where the parity value will be stored 
 410              	@
 411              	@This macro XORs all i1, i2, i3, i4, i5 inputs and stores the result in the "res" register
 412              	@
 413              	@Equivalent operation: res <-- i1 XOR i2 XOR i3 XOR i4 XOR i5
 414              	@
 415              	@Intermediate registers: r1, r2, r12
 416              	@----------------------------------------------------------------------------------
 417              	
 418              	
 419              	.macro    xor5      res, i1, i2, i3, i4, i5
 420              	    ldr         \res, [r0, #\i1]
 421              	    ldr         r1, [r0, #\i2]
 422              	    ldr         r2, [r0, #\i3]
 423              	    ldr         r12, [r0, #\i4]
 424              	    eors        \res, \res, r1
 425              	    eors        \res, \res, r2
 426              	    eors        \res, \res, r12
 427              	    ldr         r1, [r0, #\i5]
 428              	    eors        \res, \res, r1
 429              	.endm
 430              	
 431              	
 432              	@----------------------------------------------------------------------------------
 433              	@----------------------------------------XORROL MACRO------------------------------
 434              	@----------------------------------------------------------------------------------
 435              	@Used in theta step (at the beginning of each macro KeccakRound0, KeccakRound1, 
 436              	@KeccakRound2, KeccakRound3) to compute the diffusions D(x) of low halfs of the lanes
 437              	@in the OUTPUT space.
 438              	@
 439              	@It receives as inputs:
 440              	@   -aa, bb: registers containing the 32-bit half-lanes that will be XORed
 441              	@   -res: register where the resulting 
 442              	@ 
 443              	@This macro XORs the input "aa" with the input "bb" rotated left by 1 bit,
 444              	@and stores it in the "res" register.
 445              	@
 446              	@Equivalent operation: res <-- aa XOR ROTL(bb, 1)
 447              	@
 448              	@Intermediate registers: None
 449              	@----------------------------------------------------------------------------------
 450              	
 451              	
 452              	
 453              	.macro    xorrol      res, aa, bb
 454              	    eor         \res, \aa, \bb, ROR #31
 455              	.endm
 456              	
 457              	
 458              	@----------------------------------------------------------------------------------
 459              	@----------------------------------------OPCHI MACRO-------------------------------
 460              	@----------------------------------------------------------------------------------
 461              	@Used in the macros KeccakThetaRhoPiChi and KeccakThetaRhoPiChiIota to
 462              	@compute the masked Chi function for one given share.
 463              	@
 464              	@For a given row, it computes the share j of the lane i (Y^i_j) at the output of the 
 465              	@Chi step using the 32-bit half-lanes i, i+1, i+2 of the shares j+1, j+2 (X_{j+1}, X_{j+2})
 466              	@
 467              	@It receives as inputs:
 468              	@   -Ia0, Ia1, Ia2: for a given row, registers containing the 32-bit half-lanes i, i+1, i+2 of the 
 469              	@   -Ib1, Ib2: for a given row, registers containing the 32-bit half-lanes i+1, i+2 of the share j+
 470              	@   -memW: memory address where the resulting Y^i_j will be stored
 471              	@
 472              	@Equivalent operation: Y^i_j <-- f(X_{j+1}, X_{j+2}) = 
 473              	@ =X^{i}_{j+1} XOR X^{i+2}_{j+1} XOR (X^{i+1}_{j+1} & X^{i+2}_{j+1}) XOR (X^{i+1}_{j+1} & X^{i+2}_{
 474              	@
 475              	@Intermediate registers: r1, r2
 476              	@----------------------------------------------------------------------------------
 477              	
 478              	
 479              	
 480              	.macro    OpChi      memW, Ib1, Ib2, Ia0, Ia1, Ia2
 481              	    eors r1, \Ia0, \Ia2
 482              	    and r2, \Ia1, \Ia2
 483              	    eors r1, r1, r2
 484              	    and r2, \Ia1, \Ib2
 485              	    eors r1, r1, r2
 486              	    and r2, \Ib1, \Ia2 
 487              	    eors r1, r1, r2
 488              	    str r1, [r0, \memW]
 489              	.endm
 490              	
 491              	
 492              	@----------------------------------------------------------------------------------
 493              	@----------------------------------KECCAKTHETARHOPICHI MACRO-----------------------
 494              	@----------------------------------------------------------------------------------
 495              	@Used in the macros KeccakRound0, KeccakRound1, KeccakRound2, KeccakRound3 to compute
 496              	@the steps Theta, Rho, Pi Chi.
 497              	@
 498              	@It receives as inputs:
 499              	@   -reg_Aya, reg_Aye, reg_Ayi, reg_Ayo, reg_Ayu: given the diagonal defined for in-place processin
 500              	@   -reg_AyaB, reg_AyeB, reg_AyiB, reg_AyoB, reg_AyuB: given the diagonal defined for in-place proc
 501              	@   -memAya, memAye, memAyi, memAyo, memAyu: given the diagonal defined for in-place processing, me
 502              	@   -Dya, Dye, Dyi, Dyo, Dyu: registers where the diffusion values for each half-lane OF THE SHARE 
 503              	@   -memDya, memDye, memDyi, memDyo, memDyu: memory addresses where the diffusion values for each h
 504              	@   -rotAya, rotAye, rotAyi, rotAyo, rotAyu: rotation values for each half-lane according to rho st
 505              	@
 506              	@Although the group A and group B of registers contains always {r3-r7} and {r8-r12}, respectively, 
 507              	@----------------------------------------------------------------------------------
 508              	
 509              	
 510              	
 511              	.macro    KeccakThetaRhoPiChi reg_Aya, memAya, Dya, rotAya, reg_Aye, memAye, Dye, rotAye, reg_Ayi, 
 512              	    @THETA+RHO APPLIED TO S1
 513              	    push {r2, r8, r9, r10, r11, r12, lr}
 514              	
 515              	
 516              	    @Loading the half-lanes of share 1 into the group A registers
 517              	    ldr     \reg_Aya, [r0, #\memAya]
 518              	    ldr     \reg_Aye, [r0, #\memAye]
 519              	    ldr     \reg_Ayi, [r0, #\memAyi]
 520              	    ldr     \reg_Ayo, [r0, #\memAyo]
 521              	    ldr     \reg_Ayu, [r0, #\memAyu]
 522              	
 523              	    @ Applying diffusion values to the lanes of share 1
 524              	    eors    \reg_Aya, \reg_Aya, \Dya
 525              	    eors    \reg_Aye, \reg_Aye, \Dye
 526              	    eors    \reg_Ayi, \reg_Ayi, \Dyi
 527              	    eors    \reg_Ayo, \reg_Ayo, \Dyo
 528              	    eors    \reg_Ayu, \reg_Ayu, \Dyu
 529              	
 530              	
 531              	    @ Applying rotations of the Rho step to the half-lanes of share 1
 532              	    rors    \reg_Aya, #32-\rotAya
 533              	    .if  \rotAye > 0
 534              	        rors    \reg_Aye, #32-\rotAye
 535              	    .endif
 536              	    rors    \reg_Ayi, #32-\rotAyi
 537              	    rors    \reg_Ayo, #32-\rotAyo
 538              	    rors    \reg_Ayu, #32-\rotAyu
 539              	
 540              	
 541              	    @ Storing half-lanes of the share 1 after applying Theta+Rho
 542              	    str \reg_Aya, [r0, #\memAya]
 543              	    str \reg_Aye, [r0, #\memAye]
 544              	    str \reg_Ayi, [r0, #\memAyi]
 545              	    str \reg_Ayo, [r0, #\memAyo]
 546              	    str \reg_Ayu, [r0, #\memAyu]
 547              	
 548              	
 549              	
 550              	    @THETA+RHO APPLIED TO S2 
 551              	    @Loading the half-lanes of share 2 into the group B registers 
 552              	    @Loading the diffusion values for the half-lanes of share 2 into the auxiliar registers r1, r2,
 553              	    @Applying diffusion values to the half lanes of share 2
 554              	    
 555              	    ldr     \reg_AyaB, [r0, #\memAya+200]
 556              	    ldr     r1, [r0, #\memDya+40]
 557              	    ldr     \reg_AyeB, [r0, #\memAye+200]
 558              	    ldr     r2, [r0, #\memDye+40]
 559              	    ldr     \reg_AyiB, [r0, #\memAyi+200]
 560              	    ldr     lr, [r0, #\memDyi+40]
 561              	
 562              	    eors    \reg_AyaB, \reg_AyaB, r1
 563              	    eors    \reg_AyeB, \reg_AyeB, r2
 564              	    eors    \reg_AyiB, \reg_AyiB, lr
 565              	
 566              	    ldr     \reg_AyoB, [r0, #\memAyo+200]
 567              	    ldr     r1, [r0, #\memDyo+40]
 568              	    ldr     \reg_AyuB, [r0, #\memAyu+200]
 569              	    ldr     lr, [r0, #\memDyu+40]
 570              	    
 571              	    eors    \reg_AyoB, \reg_AyoB, r1
 572              	    eors    \reg_AyuB, \reg_AyuB, lr   
 573              	    
 574              	    @ Applying rotations of the Rho step to the half-lanes of share 2
 575              	    rors    \reg_AyaB, #32-\rotAya
 576              	    .if  \rotAye > 0
 577              	        rors    \reg_AyeB, #32-\rotAye
 578              	    .endif
 579              	    rors    \reg_AyiB, #32-\rotAyi
 580              	    rors    \reg_AyoB, #32-\rotAyo
 581              	    rors    \reg_AyuB, #32-\rotAyu
 582              	
 583              	
 584              	
 585              	    @PI+CHI APPLIED TO SHARE 0 (SHARES 1 - 2). 
 586              	    @At this point, the register values are:
 587              	    @   - r3-r7: half-lanes of the share 1 with Theta and Rho steps applied (Group A)
 588              	    @   - r8-r12: half-lanes of the share 2 with Theta and Rho steps applied (Group B)
 589              	
 590              	    @The following expansions of OpChi macro computes the output share Y_0 from input shares
 591              	    @X_1, X_2 and write them in the corresponding memory address according to in-place processing
 592              	    @(it will be one of the other positions in the diagonal, but not the same)
 593              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 594              	
 595              	    .if     \memAya < 599
 596              	        OpChi   #\memAya+400, r9, r10, r3, r4, r5
 597              	        OpChi   #\memAye+400, r10, r11, r4, r5, r6
 598              	        OpChi   #\memAyi+400, r11, r12, r5, r6, r7
 599              	        OpChi   #\memAyo+400, r12, r8, r6, r7, r3
 600              	        OpChi   #\memAyu+400, r8, r9, r7, r3, r4
 601              	    .else 
 602              	        OpChi   #\memAya-800, r9, r10, r3, r4, r5
 603              	        OpChi   #\memAye-800, r10, r11, r4, r5, r6
 604              	        OpChi   #\memAyi-800, r11, r12, r5, r6, r7
 605              	        OpChi   #\memAyo-800, r12, r8, r6, r7, r3
 606              	        OpChi   #\memAyu-800, r8, r9, r7, r3, r4
 607              	    .endif
 608              	
 609              	
 610              	
 611              	    @THETA+RHO APPLIED TO S0
 612              	
 613              	    @Loading the half-lanes of share 0 into the group A of registers 
 614              	    @Loading the diffusion values for the half-lanes of share 2 into the auxiliar registers r1, r2,
 615              	    @Applying diffusion values to the half lanes of share 2
 616              	
 617              	    ldr     \reg_Aya, [r0, #\memAya-200]
 618              	    ldr     r1, [r0, #\memDya-40]
 619              	    ldr     \reg_Aye, [r0, #\memAye-200]
 620              	    ldr     r2, [r0, #\memDye-40]
 621              	    ldr     \reg_Ayi, [r0, #\memAyi-200]
 622              	    ldr     lr, [r0, #\memDyi-40]
 623              	
 624              	    eors    \reg_Aya, \reg_Aya, r1
 625              	    eors    \reg_Aye, \reg_Aye, r2
 626              	    eors    \reg_Ayi, \reg_Ayi, lr
 627              	
 628              	
 629              	    ldr     \reg_Ayo, [r0, #\memAyo-200]
 630              	    ldr     r1, [r0, #\memDyo-40]
 631              	    ldr     \reg_Ayu, [r0, #\memAyu-200]
 632              	    ldr     lr, [r0, #\memDyu-40]
 633              	    
 634              	    eors    \reg_Ayo, \reg_Ayo, r1
 635              	    eors    \reg_Ayu, \reg_Ayu, lr
 636              	    
 637              	    @ Applying rotations of the Rho step to the half-lanes of share 2
 638              	
 639              	    rors    \reg_Aya, #32-\rotAya
 640              	    .if  \rotAye > 0
 641              	        rors    \reg_Aye, #32-\rotAye
 642              	    .endif
 643              	    rors    \reg_Ayi, #32-\rotAyi
 644              	    rors    \reg_Ayo, #32-\rotAyo
 645              	    rors    \reg_Ayu, #32-\rotAyu
 646              	
 647              	
 648              	
 649              	    @PI+CHI APPLIED TO SHARE 1 (SHARES 2 - 0)
 650              	    @At this point, the register values are:
 651              	    @   - r3-r7: half-lanes of the share 0 with Theta and Rho steps applied (Group A)
 652              	    @   - r8-r12: half-lanes of the share 2 with Theta and Rho steps applied (Group B)
 653              	    @The following expansions of OpChi macro computes the output share Y_1 from input shares
 654              	    @X_2, X_0 and write them in the corresponding memory address according to in-place processing
 655              	    @(it will be one of the other positions in the diagonal, but not the same)
 656              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 657              	    
 658              	    .if     \memAya < 599
 659              	        OpChi   #\memAya+600, r4, r5, r8, r9, r10
 660              	        OpChi   #\memAye+600, r5, r6, r9, r10, r11
 661              	        OpChi   #\memAyi+600, r6, r7, r10, r11, r12
 662              	        OpChi   #\memAyo+600, r7, r3, r11, r12, r8
 663              	        OpChi   #\memAyu+600, r3, r4, r12, r8, r9
 664              	    .else 
 665              	        OpChi   #\memAya-600, r4, r5, r8, r9, r10
 666              	        OpChi   #\memAye-600, r5, r6, r9, r10, r11
 667              	        OpChi   #\memAyi-600, r6, r7, r10, r11, r12
 668              	        OpChi   #\memAyo-600, r7, r3, r11, r12, r8
 669              	        OpChi   #\memAyu-600, r3, r4, r12, r8, r9
 670              	    .endif
 671              	
 672              	
 673              	    @PI+CHI APPLIED TO SHARE 2 (SHARES 0 - 1). Stack at this point (old --> new): r8-r12: Diffusion
 674              	    
 675              	    @Loading the half-lanes of share 1 (Theta+Rho already applied) into the group B of registers 
 676              	
 677              	    ldr     \reg_AyaB, [r0, #\memAya]             
 678              	    ldr     \reg_AyeB, [r0, #\memAye]         
 679              	    ldr     \reg_AyiB, [r0, #\memAyi]            
 680              	    ldr     \reg_AyoB, [r0, #\memAyo]           
 681              	    ldr     \reg_AyuB, [r0, #\memAyu]           
 682              	
 683              	    @At this point, the register values are:
 684              	    @   - r3-r7: half-lanes of the share 0 with Theta and Rho steps applied (Group A)
 685              	    @   - r8-r12: half-lanes of the share 1 with Theta and Rho steps applied (Group B)
 686              	    @The following expansions of OpChi macro computes the output share Y_2 from input shares
 687              	    @X_0, X_1 and write them in the corresponding memory address according to in-place processing
 688              	    @(it will be one of the other positions in the diagonal, but not the same)
 689              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 690              	
 691              	    .if     \memAya < 599
 692              	        OpChi   #\memAya+800, r9, r10, r3, r4, r5
 693              	        OpChi   #\memAye+800, r10, r11, r4, r5, r6
 694              	        OpChi   #\memAyi+800, r11, r12, r5, r6, r7
 695              	        OpChi   #\memAyo+800, r12, r8, r6, r7, r3
 696              	        OpChi   #\memAyu+800, r8, r9, r7, r3, r4
 697              	    .else 
 698              	        OpChi   #\memAya-400, r9, r10, r3, r4, r5
 699              	        OpChi   #\memAye-400, r10, r11, r4, r5, r6
 700              	        OpChi   #\memAyi-400, r11, r12, r5, r6, r7
 701              	        OpChi   #\memAyo-400, r12, r8, r6, r7, r3
 702              	        OpChi   #\memAyu-400, r8, r9, r7, r3, r4
 703              	    .endif
 704              	
 705              	
 706              	    pop {r2, r8, r9, r10, r11, r12, lr}
 707              	.endm
 708              	
 709              	
 710              	
 711              	@----------------------------------------------------------------------------------
 712              	@--------------------------------KECCAKTHETARHOPICHIIOTA MACRO---------------------
 713              	@----------------------------------------------------------------------------------
 714              	@Used in the macros KeccakRound0, KeccakRound1, KeccakRound2, KeccakRound3 to compute
 715              	@the steps Theta, Rho, Pi, Chi, and apply the Round Constant of Iota step to lane Aba (0,0)
 716              	@
 717              	@It receives as inputs:
 718              	@   -memAya, memAye, memAyi, memAyo, memAyu: given the diagonal defined for in-place processing, me
 719              	@   -Dya, Dye, Dyi, Dyo, Dyu: registers where the diffusion values for each half-lane OF THE SHARE 
 720              	@   -rotAya, rotAye, rotAyi, rotAyo, rotAyu: rotation values for each half-lane according to rho st
 721              	@   -memDya, memDye, memDyi, memDyo, memDyu: memory addresses where the diffusion values for each h
 722              	@   -offset: offset applied to access to the round constant of Iota step
 723              	@   -last: flag to indicate if this is the last Iota applied in the fourth cyclic round
 724              	@Registers where lanes will be stores are fixed, due to the fact that this macro processes always t
 725              	@same diagonal (Aba, Age, Aki, Amo, Asu) --> Registers {r3-r7} and {r8-r12} of groups A and B, resp
 726              	
 727              	@----------------------------------------------------------------------------------
 728              	
 729              	.macro    KeccakThetaRhoPiChiIota  memAya, Dya, memAye, Dye, rotAye, memAyi, Dyi, rotAyi, memAyo, D
 730              	    
 731              	    @THETA+RHO APPLIED TO S1
 732              	    push {r2, r8, r9, r10, r11, r12, lr}
 733              	
 734              	    @Loading the half-lanes of share 1 into the group A registers
 735              	    ldr     r3, [r0, #\memAya]
 736              	    ldr     r4, [r0, #\memAye]
 737              	    ldr     r5, [r0, #\memAyi]
 738              	    ldr     r6, [r0, #\memAyo]
 739              	    ldr     r7, [r0, #\memAyu]
 740              	
 741              	    @ Applying diffusion values to the lanes of share 1
 742              	    eors    r3, r3, \Dya
 743              	    eors    r4, r4, \Dye
 744              	    eors    r5, r5, \Dyi
 745              	    eors    r6, r6, \Dyo
 746              	    eors    r7, r7, \Dyu
 747              	
 748              	    @ Applying rotations of the Rho step to the half-lanes of share 1
 749              	    .if  \rotAye > 0
 750              	        rors    r4, #32-\rotAye
 751              	    .endif
 752              	    rors    r5, #32-\rotAyi
 753              	    rors    r6, #32-\rotAyo
 754              	    rors    r7, #32-\rotAyu
 755              	
 756              	    @ Storing half-lanes of the share 1 after applying Theta+Rho
 757              	    str r3, [r0, #\memAya]
 758              	    str r4, [r0, #\memAye]
 759              	    str r5, [r0, #\memAyi]
 760              	    str r6, [r0, #\memAyo]
 761              	    str r7, [r0, #\memAyu]
 762              	
 763              	
 764              	
 765              	    @THETA+RHO APPLIED TO S2 
 766              	    @Loading the half-lanes of share 2 into the group B registers 
 767              	    @Loading the diffusion values for the half-lanes of share 2 into the auxiliar registers r1, r2,
 768              	    @Applying diffusion values to the half lanes of share 2  
 769              	    
 770              	    ldr     r8, [r0, #\memAya+200]
 771              	    ldr     r1, [r0, #\memDya+40]
 772              	    ldr     r9, [r0, #\memAye+200]
 773              	    ldr     r2, [r0, #\memDye+40]
 774              	    ldr     r10, [r0, #\memAyi+200]
 775              	    ldr     lr, [r0, #\memDyi+40]
 776              	
 777              	    eors    r8, r8, r1
 778              	    eors    r9, r9, r2
 779              	    eors    r10, r10, lr
 780              	
 781              	    ldr     r11, [r0, #\memAyo+200]
 782              	    ldr     r1, [r0, #\memDyo+40]
 783              	    ldr     r12, [r0, #\memAyu+200]
 784              	    ldr     lr, [r0, #\memDyu+40]
 785              	    
 786              	    eors    r11, r11, r1
 787              	    eors    r12, r12, lr
 788              	
 789              	    @ Applying rotations of the Rho step to the half-lanes of share 2     
 790              	    .if  \rotAye > 0
 791              	        rors    r9, #32-\rotAye
 792              	    .endif
 793              	    rors    r10, #32-\rotAyi
 794              	    rors    r11, #32-\rotAyo
 795              	    rors    r12, #32-\rotAyu
 796              	
 797              	
 798              	
 799              	
 800              	    @PI+CHI APPLIED TO SHARE 0 (SHARES 1 - 2)
 801              	
 802              	    @At this point, the register values are:
 803              	    @   - r3-r7: half-lanes of the share 1 with Theta and Rho steps applied (Group A)
 804              	    @   - r8-r12: half-lanes of the share 2 with Theta and Rho steps applied (Group B)
 805              	
 806              	    @The following expansions of OpChi macro computes the output share Y_0 from input shares
 807              	    @X_1, X_2 and write them in the corresponding memory address according to in-place processing
 808              	    @(it will be one of the other positions in the diagonal, but not the same)
 809              	
 810              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 811              	    .if     \memAya < 599
 812              	        OpChi   #\memAya+400, r9, r10, r3, r4, r5
 813              	        OpChi   #\memAye+400, r10, r11, r4, r5, r6
 814              	        OpChi   #\memAyi+400, r11, r12, r5, r6, r7
 815              	        OpChi   #\memAyo+400, r12, r8, r6, r7, r3
 816              	        OpChi   #\memAyu+400, r8, r9, r7, r3, r4
 817              	    .else 
 818              	        OpChi   #\memAya-800, r9, r10, r3, r4, r5
 819              	        OpChi   #\memAye-800, r10, r11, r4, r5, r6
 820              	        OpChi   #\memAyi-800, r11, r12, r5, r6, r7
 821              	        OpChi   #\memAyo-800, r12, r8, r6, r7, r3
 822              	        OpChi   #\memAyu-800, r8, r9, r7, r3, r4
 823              	    .endif
 824              	
 825              	
 826              	
 827              	
 828              	    @THETA+RHO APPLIED TO S0. Stack at this point (old --> new): r8-r12: Diffusions, r3-r7: SHARE 1
 829              	
 830              	    @Loading the half-lanes of share 0 into the group A of registers 
 831              	    @Loading the diffusion values for the half-lanes of share 2 into the auxiliar registers r1, r2,
 832              	    @Applying diffusion values to the half lanes of share 2
 833              	
 834              	    ldr     r3, [r0, #\memAya-200]
 835              	    ldr     r1, [r0, #\memDya-40]
 836              	    ldr     r4, [r0, #\memAye-200]
 837              	    ldr     r2, [r0, #\memDye-40]
 838              	    ldr     r5, [r0, #\memAyi-200]
 839              	    ldr     lr, [r0, #\memDyi-40]
 840              	
 841              	    eors    r3, r3, r1
 842              	    eors    r4, r4, r2
 843              	    eors    r5, r5, lr
 844              	
 845              	
 846              	    ldr     r6, [r0, #\memAyo-200]
 847              	    ldr     r1, [r0, #\memDyo-40]
 848              	    ldr     r7, [r0, #\memAyu-200]
 849              	    ldr     lr, [r0, #\memDyu-40]
 850              	    
 851              	    eors    r6, r6, r1
 852              	    eors    r7, r7, lr
 853              	
 854              	    @ Applying rotations of the Rho step to the half-lanes of share 2
 855              	    .if  \rotAye > 0
 856              	        rors    r4, #32-\rotAye
 857              	    .endif
 858              	    rors    r5, #32-\rotAyi
 859              	    rors    r6, #32-\rotAyo
 860              	    rors    r7, #32-\rotAyu
 861              	
 862              	
 863              	
 864              	
 865              	    @PI+CHI APPLIED TO SHARE 1 (SHARES 2 - 0)
 866              	    @At this point, the register values are:
 867              	    @   - r3-r7: half-lanes of the share 0 with Theta and Rho steps applied (Group A)
 868              	    @   - r8-r12: half-lanes of the share 2 with Theta and Rho steps applied (Group B)
 869              	    @The following expansions of OpChi macro computes the output share Y_1 from input shares
 870              	    @X_2, X_0 and write them in the corresponding memory address according to in-place processing
 871              	    @(it will be one of the other positions in the diagonal, but not the same)
 872              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 873              	
 874              	    .if     \memAya < 599
 875              	        OpChi   #\memAya+600, r4, r5, r8, r9, r10
 876              	        OpChi   #\memAye+600, r5, r6, r9, r10, r11
 877              	        OpChi   #\memAyi+600, r6, r7, r10, r11, r12
 878              	        OpChi   #\memAyo+600, r7, r3, r11, r12, r8
 879              	        OpChi   #\memAyu+600, r3, r4, r12, r8, r9
 880              	    .else 
 881              	        OpChi   #\memAya-600, r4, r5, r8, r9, r10
 882              	        OpChi   #\memAye-600, r5, r6, r9, r10, r11
 883              	        OpChi   #\memAyi-600, r6, r7, r10, r11, r12
 884              	        OpChi   #\memAyo-600, r7, r3, r11, r12, r8
 885              	        OpChi   #\memAyu-600, r3, r4, r12, r8, r9
 886              	    .endif
 887              	
 888              	
 889              	
 890              	    @PI+CHI APPLIED TO SHARE 2 (SHARES 0 - 1).
 891              	    @Loading the half-lanes of share 1 (Theta+Rho already applied) into the group B of registers
 892              	
 893              	    ldr     r8, [r0, #\memAya]
 894              	    ldr     r9, [r0, #\memAye]
 895              	    ldr     r10, [r0, #\memAyi]
 896              	    ldr     r11, [r0, #\memAyo]
 897              	    ldr     r12, [r0, #\memAyu]
 898              	
 899              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 900              	    .if     \memAya < 599
 901              	        OpChi   #\memAye+800, r10, r11, r4, r5, r6
 902              	        OpChi   #\memAyi+800, r11, r12, r5, r6, r7
 903              	        OpChi   #\memAyo+800, r12, r8, r6, r7, r3
 904              	        OpChi   #\memAyu+800, r8, r9, r7, r3, r4
 905              	    .else 
 906              	        OpChi   #\memAye-400, r10, r11, r4, r5, r6
 907              	        OpChi   #\memAyi-400, r11, r12, r5, r6, r7
 908              	        OpChi   #\memAyo-400, r12, r8, r6, r7, r3
 909              	        OpChi   #\memAyu-400, r8, r9, r7, r3, r4
 910              	    .endif
 911              	
 912              	    @Loading the address where the Round Constants table starts
 913              	    ldr     r1, [r0, #mRC]
 914              	
 915              	    @Chi step applied to lane (0,0)
 916              	    eors r6, r3, r5
 917              	    and r7, r4, r5
 918              	    eors r6, r6, r7
 919              	    and r7, r4, r10
 920              	    eors r6, r6, r7
 921              	    and r7, r9, r5
 922              	    eors r6, r6, r7  
 923              	
 924              	    @Loading the Round Constant of Iota step applying the input offset to the memory address where 
 925              	    ldr     r4, [r1, #\offset]
 926              	
 927              	    @Lane(0,0) XOR RoundConstant 
 928              	    eors r6, r6, r4
 929              	
 930              	    .if  \last == 1
 931              	    ldr     r4, [r1, #32]!
 932              	    str     r1, [r0, #mRC]
 933              	    cmp     r4, #0xFF
 934              	    .endif
 935              	
 936              	    @Writing-back the lane (0,0) after applying Iota step in the writing memory zone
 937              	    .if     \memAya <599
 938              	        str     r6, [r0, #\memAya+800]
 939              	    .else
 940              	        str     r6, [r0, #\memAya-400]
 941              	    .endif
 942              	
 943              	
 944              	    pop {r2, r8, r9, r10, r11, r12, lr}
 945              	.endm
 946              	
 947              	
 948              	
