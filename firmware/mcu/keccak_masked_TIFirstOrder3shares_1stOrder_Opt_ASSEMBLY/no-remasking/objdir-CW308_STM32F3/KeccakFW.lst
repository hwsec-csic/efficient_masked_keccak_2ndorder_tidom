 227:KeccakFW.c    **** uint8_t get_pt(uint8_t* pt, uint8_t len)
 228:KeccakFW.c    **** {   
 229:KeccakFW.c    ****     int i;
 230:KeccakFW.c    ****     create_state(pt, len);
 231:KeccakFW.c    ****     mask_state();
 232:KeccakFW.c    ****     bit_interleave(s0, I0);
 233:KeccakFW.c    ****     bit_interleave(s1, I1);
 234:KeccakFW.c    ****     bit_interleave(s2, I2);
 235:KeccakFW.c    ****     for(i=0; i<200; i++)
 236:KeccakFW.c    ****     {
 237:KeccakFW.c    ****         ISHARES[i] = I0[i];
 238:KeccakFW.c    ****         ISHARES[i+200] = I1[i];
 239:KeccakFW.c    ****         ISHARES[i+400] = I2[i];
 240:KeccakFW.c    ****     }
 241:KeccakFW.c    ****     *SCB_DEMCR |= 0x01000000;
 242:KeccakFW.c    ****     *DWT_CYCCNT = 0; // reset the counter
 243:KeccakFW.c    ****     *DWT_CONTROL |= 1 ; // enable the counter
 244:KeccakFW.c    ****     x = *DWT_CYCCNT;
 245:KeccakFW.c    ****     trigger_high();
 246:KeccakFW.c    ****     KeccakF1600_StatePermute(ISHARES);
 247:KeccakFW.c    ****     trigger_low();
 248:KeccakFW.c    ****     y = *DWT_CYCCNT;
 249:KeccakFW.c    ****     delta = (y - x);
 250:KeccakFW.c    **** 	simpleserial_put('r', 16, pt);
 251:KeccakFW.c    **** 	return 0x00;
 252:KeccakFW.c    **** }
