  41:KeccakFW.c    **** // ***********************************************************************
  42:KeccakFW.c    **** // ******************************* CHACHA20 ******************************
  43:KeccakFW.c    **** // ***********************************************************************
  44:KeccakFW.c    **** 
  45:KeccakFW.c    **** #define CHACHA20_BLOCK_SIZE 64
  46:KeccakFW.c    **** #define SEED_SIZE 32
  47:KeccakFW.c    **** 
  48:KeccakFW.c    **** int seed_counter = 0;
  49:KeccakFW.c    **** uint32_t prng_state;
  50:KeccakFW.c    **** uint8_t seed_chacha20[32];
  51:KeccakFW.c    **** 
  52:KeccakFW.c    **** typedef struct {
  53:KeccakFW.c    ****     uint32_t state[16];
  54:KeccakFW.c    ****     uint8_t keystream[CHACHA20_BLOCK_SIZE];
  55:KeccakFW.c    ****     int keystream_pos;
  56:KeccakFW.c    **** } chacha20_prng_t;
  57:KeccakFW.c    **** 
  58:KeccakFW.c    **** static chacha20_prng_t prng;
  59:KeccakFW.c    **** static const uint32_t chacha20_constants[4] = {
  60:KeccakFW.c    ****     0x61707865, 0x3320646e, 0x79622d32, 0x6b206574
  61:KeccakFW.c    **** };
  62:KeccakFW.c    **** 
  63:KeccakFW.c    **** #define ROTL(a,b) (((a) << (b)) | ((a) >> (32 - (b))))
  64:KeccakFW.c    **** #define QUARTERROUND(a,b,c,d) \
  65:KeccakFW.c    ****     a += b; d ^= a; d = ROTL(d,16); \
  66:KeccakFW.c    ****     c += d; b ^= c; b = ROTL(b,12); \
  67:KeccakFW.c    ****     a += b; d ^= a; d = ROTL(d,8);  \
  68:KeccakFW.c    ****     c += d; b ^= c; b = ROTL(b,7);
  69:KeccakFW.c    **** 
  70:KeccakFW.c    **** static void chacha20_block(uint32_t out[16], const uint32_t in[16]) {
  71:KeccakFW.c    ****     uint32_t x[16];
  72:KeccakFW.c    ****     memcpy(x, in, sizeof(uint32_t) * 16);
  73:KeccakFW.c    **** 
  74:KeccakFW.c    ****     for (int i = 0; i < 10; i++) {
  75:KeccakFW.c    ****         QUARTERROUND(x[0], x[4], x[8], x[12])
  76:KeccakFW.c    ****         QUARTERROUND(x[1], x[5], x[9], x[13])
  77:KeccakFW.c    ****         QUARTERROUND(x[2], x[6], x[10], x[14])
  78:KeccakFW.c    ****         QUARTERROUND(x[3], x[7], x[11], x[15])
  79:KeccakFW.c    **** 
  80:KeccakFW.c    ****         QUARTERROUND(x[0], x[5], x[10], x[15])
  81:KeccakFW.c    ****         QUARTERROUND(x[1], x[6], x[11], x[12])
  82:KeccakFW.c    ****         QUARTERROUND(x[2], x[7], x[8], x[13])
  83:KeccakFW.c    ****         QUARTERROUND(x[3], x[4], x[9], x[14])
  84:KeccakFW.c    ****     }
  85:KeccakFW.c    **** 
  86:KeccakFW.c    ****     for (int i = 0; i < 16; i++) {
  87:KeccakFW.c    ****         out[i] = x[i] + in[i];
  88:KeccakFW.c    ****     }
  89:KeccakFW.c    **** }
  90:KeccakFW.c    **** 
  91:KeccakFW.c    **** void prng_init(const uint8_t seed[32]) {
  92:KeccakFW.c    ****     prng.state[0] = chacha20_constants[0];
  93:KeccakFW.c    ****     prng.state[1] = chacha20_constants[1];
  94:KeccakFW.c    ****     prng.state[2] = chacha20_constants[2];
  95:KeccakFW.c    ****     prng.state[3] = chacha20_constants[3];
  96:KeccakFW.c    **** 
  97:KeccakFW.c    ****     for (int i = 0; i < 8; i++) {
  98:KeccakFW.c    ****         prng.state[4 + i] =
  99:KeccakFW.c    ****             ((uint32_t)seed[i*4]) |
 100:KeccakFW.c    ****             ((uint32_t)seed[i*4+1] << 8) |
 101:KeccakFW.c    ****             ((uint32_t)seed[i*4+2] << 16) |
 102:KeccakFW.c    ****             ((uint32_t)seed[i*4+3] << 24);
 103:KeccakFW.c    ****     }
 104:KeccakFW.c    **** 
 105:KeccakFW.c    ****     prng.state[12] = 0; // counter
 106:KeccakFW.c    ****     prng.state[13] = 0; prng.state[14] = 0; prng.state[15] = 0; // nonce
 107:KeccakFW.c    **** 
 108:KeccakFW.c    ****     prng.keystream_pos = CHACHA20_BLOCK_SIZE;
 109:KeccakFW.c    **** }
 110:KeccakFW.c    **** 
 111:KeccakFW.c    **** static void prng_generate_block() {
 112:KeccakFW.c    ****     chacha20_block((uint32_t*)prng.keystream, prng.state);
 113:KeccakFW.c    ****     prng.state[12]++;
 114:KeccakFW.c    ****     prng.keystream_pos = 0;
 115:KeccakFW.c    **** }
 116:KeccakFW.c    **** 
 117:KeccakFW.c    **** uint8_t prng_get_byte() {
 118:KeccakFW.c    ****     if (prng.keystream_pos >= CHACHA20_BLOCK_SIZE) {
 119:KeccakFW.c    ****         prng_generate_block();
 120:KeccakFW.c    ****     }
 121:KeccakFW.c    ****     return prng.keystream[prng.keystream_pos++];
 122:KeccakFW.c    **** }
 123:KeccakFW.c    **** 
 124:KeccakFW.c    **** uint64_t rand_share_64() {
 125:KeccakFW.c    ****     uint64_t r = 0;
 126:KeccakFW.c    ****     for (int i = 0; i < 8; i++) {
 127:KeccakFW.c    ****         r |= ((uint64_t)prng_get_byte()) << (8 * i);
 128:KeccakFW.c    ****     }
 129:KeccakFW.c    ****     return r;
 130:KeccakFW.c    **** }
