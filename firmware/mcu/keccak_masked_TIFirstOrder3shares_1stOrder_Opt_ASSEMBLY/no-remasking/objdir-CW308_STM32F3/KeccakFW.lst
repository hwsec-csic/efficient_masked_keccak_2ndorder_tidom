 203:KeccakFW.c    **** uint8_t get_seed(uint8_t* seed, uint8_t len)
 204:KeccakFW.c    **** {
 205:KeccakFW.c    ****     int i;
 206:KeccakFW.c    ****     for(i=0; i<16; i++)
 207:KeccakFW.c    ****     {
 208:KeccakFW.c    ****         seed_chacha20[i+(seed_counter*16)] = seed[i]; 
 209:KeccakFW.c    ****     }
 210:KeccakFW.c    ****     seed_counter = (seed_counter + 1) % 2;
 211:KeccakFW.c    ****     if(seed_counter == 0)
 212:KeccakFW.c    ****     {
 213:KeccakFW.c    ****         prng_init(seed_chacha20);
 214:KeccakFW.c    ****     }
 215:KeccakFW.c    ****     simpleserial_put('r', 16, seed);
 216:KeccakFW.c    ****     return 0x00;
 217:KeccakFW.c    **** }
