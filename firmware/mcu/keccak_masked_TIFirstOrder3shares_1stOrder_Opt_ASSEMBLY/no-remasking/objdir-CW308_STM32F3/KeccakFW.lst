 134:KeccakFW.c    **** // *****************************  BIT INTERLEAVING ***************************
 135:KeccakFW.c    **** // ***************************************************************************
 136:KeccakFW.c    **** void bit_interleave(const uint8_t s0[200], uint8_t I0[200]) {
 137:KeccakFW.c    ****     for (int blk = 0; blk < 200; blk += 8) {
 138:KeccakFW.c    ****         uint64_t word = 0;
 139:KeccakFW.c    ****         for (int j = 0; j < 8; j++) {
 140:KeccakFW.c    ****             word |= ((uint64_t)s0[blk + j]) << (8 * j);
 141:KeccakFW.c    ****         }
 142:KeccakFW.c    **** 
 143:KeccakFW.c    ****         uint8_t h[8] = {0};
 144:KeccakFW.c    **** 
 145:KeccakFW.c    ****         for (int bit = 0; bit < 64; bit++) {
 146:KeccakFW.c    ****             int byte_out, bit_out;
 147:KeccakFW.c    ****             uint8_t bitval = (word >> bit) & 1;
 148:KeccakFW.c    **** 
 149:KeccakFW.c    ****             if ((bit / 16) < 4) { 
 150:KeccakFW.c    ****                 if ((bit % 2) == 0)
 151:KeccakFW.c    ****                     byte_out = (bit / 16);      
 152:KeccakFW.c    ****                 else
 153:KeccakFW.c    ****                     byte_out = 4 + (bit / 16);  
 154:KeccakFW.c    ****                 bit_out = (bit % 16) / 2;
 155:KeccakFW.c    ****             } else {
 156:KeccakFW.c    ****                 continue; 
 157:KeccakFW.c    ****             }
 158:KeccakFW.c    **** 
 159:KeccakFW.c    ****             h[byte_out] |= bitval << bit_out;
 160:KeccakFW.c    ****         }
 161:KeccakFW.c    **** 
 162:KeccakFW.c    ****         for (int i = 0; i < 8; i++) {
 163:KeccakFW.c    ****             I0[blk + i] = h[i];
 164:KeccakFW.c    ****         }
 165:KeccakFW.c    ****     }
 166:KeccakFW.c    **** }
 167:KeccakFW.c    **** 
 168:KeccakFW.c    **** 
 169:KeccakFW.c    **** void bit_deinterleave(const uint8_t I0[200], uint8_t s0[200]) {
 170:KeccakFW.c    ****     for (int blk = 0; blk < 200; blk += 8) {
 171:KeccakFW.c    ****         uint64_t word = 0;
 172:KeccakFW.c    **** 
 173:KeccakFW.c    ****         for (int group = 0; group < 4; group++) {
 174:KeccakFW.c    ****             uint8_t even = I0[blk + group];     
 175:KeccakFW.c    ****             uint8_t odd  = I0[blk + 4 + group];  
 176:KeccakFW.c    **** 
 177:KeccakFW.c    ****             for (int k = 0; k < 8; k++) {
 178:KeccakFW.c    ****                 uint8_t bit_even = (even >> k) & 1;
 179:KeccakFW.c    ****                 uint8_t bit_odd  = (odd  >> k) & 1;
 180:KeccakFW.c    **** 
 181:KeccakFW.c    ****                 int base = group * 16;
 182:KeccakFW.c    **** 
 183:KeccakFW.c    ****                 word |= ((uint64_t)bit_even) << (base + 2 * k);
 184:KeccakFW.c    ****                 word |= ((uint64_t)bit_odd)  << (base + 2 * k + 1);
 185:KeccakFW.c    ****             }
 186:KeccakFW.c    ****         }
 187:KeccakFW.c    **** 
 188:KeccakFW.c    ****         for (int j = 0; j < 8; j++) {
 189:KeccakFW.c    ****             s0[blk + j] = (word >> (8 * j)) & 0xFF;
 190:KeccakFW.c    ****         }
 191:KeccakFW.c    ****     }
 192:KeccakFW.c    **** }
