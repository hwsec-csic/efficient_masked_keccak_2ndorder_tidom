 255:KeccakFW.c    **** uint8_t get_res(uint8_t* lane, uint8_t len)
 256:KeccakFW.c    **** {   
 257:KeccakFW.c    ****     int j, i;
 258:KeccakFW.c    ****     uint8_t bytes_st_msg[8];
 259:KeccakFW.c    **** 
 260:KeccakFW.c    ****     for(i=0; i<200; i++)
 261:KeccakFW.c    ****     {
 262:KeccakFW.c    ****         I0[i] = ISHARES[i+0];
 263:KeccakFW.c    ****         I1[i] = ISHARES[i+200];
 264:KeccakFW.c    ****         I2[i] = ISHARES[i+400];
 265:KeccakFW.c    ****     }
 266:KeccakFW.c    ****     bit_deinterleave(I0,s0);
 267:KeccakFW.c    ****     bit_deinterleave(I1,s1);
 268:KeccakFW.c    ****     bit_deinterleave(I2,s2);
 269:KeccakFW.c    ****     
 270:KeccakFW.c    ****     unmask_state();
 271:KeccakFW.c    ****     for(i=0;i<25;i++)
 272:KeccakFW.c    ****     {
 273:KeccakFW.c    ****         for(j=0;j<8;j++)
 274:KeccakFW.c    ****         {
 275:KeccakFW.c    ****             bytes_st[i][j] = rec[0+8*i+j];
 276:KeccakFW.c    ****         }
 277:KeccakFW.c    ****     }
 278:KeccakFW.c    **** 
 279:KeccakFW.c    ****     i=(int)lane[0];
 280:KeccakFW.c    ****     for(j=0;j<8;j++)
 281:KeccakFW.c    ****     {
 282:KeccakFW.c    ****         bytes_st_msg[j] = bytes_st[i][j];
 283:KeccakFW.c    ****     }    
 284:KeccakFW.c    **** 
 285:KeccakFW.c    ****     simpleserial_put('m', 8, bytes_st_msg);
 286:KeccakFW.c    **** 	return 0x00;
 287:KeccakFW.c    **** }
