 1090              	@------------------------------------KECCAKROUND1 MACRO----------------------------
 1091              	@----------------------------------------------------------------------------------
 1092              	@This macro performs the second cyclic round of Keccak
 1093              	@----------------------------------------------------------------------------------
 1094              	
 1095              	
 1096              	.macro    KeccakRound1
 1097              	    @DIFFUSION SHARE 0
 1098              	    xor5        r3,  Asu0_s0_M2, Agu0_s0_M2, Amu0_s0_M2, Abu1_s0_M2, Aku1_s0_M2
 1099              	    xor5        r7,  Age1_s0_M2, Ame0_s0_M2, Abe0_s0_M2, Ake1_s0_M2, Ase1_s0_M2
 1100              	    xorrol      r6, r3, r7
 1101              	    str         r6, [r0, #mDa0_s0]
 1102              	    xor5        r6,  Asu1_s0_M2, Agu1_s0_M2, Amu1_s0_M2, Abu0_s0_M2, Aku0_s0_M2
 1103              	    xor5        lr,  Age0_s0_M2, Ame1_s0_M2, Abe1_s0_M2, Ake0_s0_M2, Ase0_s0_M2
 1104              	    eors        r8, r6, lr
 1105              	    str         r8, [r0, #mDa1_s0]
 1106              	
 1107              	    xor5        r5,  Aki1_s0_M2, Asi1_s0_M2, Agi0_s0_M2, Ami1_s0_M2, Abi0_s0_M2
 1108              	    xorrol      r9, r5, r6
 1109              	    str         r9, [r0, #mDo0_s0]
 1110              	    xor5        r4,  Aki0_s0_M2, Asi0_s0_M2, Agi1_s0_M2, Ami0_s0_M2, Abi1_s0_M2
 1111              	    eors        r3, r3, r4
 1112              	    str         r3, [r0, #mDo1_s0]
 1113              	
 1114              	    xor5        r3,  Aba0_s0_M2, Aka1_s0_M2, Asa0_s0_M2, Aga0_s0_M2, Ama1_s0_M2
 1115              	    xorrol      r10, r3, r4
 1116              	    str         r10, [r0, #mDe0_s0]
 1117              	    xor5        r6,  Aba1_s0_M2, Aka0_s0_M2, Asa1_s0_M2, Aga1_s0_M2, Ama0_s0_M2
 1118              	    eors        r11, r6, r5
 1119              	    str         r11, [r0, #mDe1_s0]
 1120              	
 1121              	    xor5        r4,  Amo0_s0_M2, Abo1_s0_M2, Ako0_s0_M2, Aso1_s0_M2, Ago0_s0_M2
 1122              	    xorrol      r5, lr, r4
 1123              	    str         r5, [r0, #mDi0_s0]
 1124              	    xor5        r5,  Amo1_s0_M2, Abo0_s0_M2, Ako1_s0_M2, Aso0_s0_M2, Ago1_s0_M2
 1125              	    eors        r2, r7, r5
 1126              	    str         r2, [r0, #mDi1_s0]
 1127              	
 1128              	    xorrol      r12, r5, r6
 1129              	    str         r12, [r0, #mDu0_s0]
 1130              	    eors        lr, r4, r3
 1131              	    str         lr, [r0, #mDu1_s0]
 1132              	
 1133              	
 1134              	
 1135              	    @DIFFUSION SHARE 2
 1136              	    xor5        r3,  Asu0_s2_M2, Agu0_s2_M2, Amu0_s2_M2, Abu1_s2_M2, Aku1_s2_M2
 1137              	    xor5        r7,  Age1_s2_M2, Ame0_s2_M2, Abe0_s2_M2, Ake1_s2_M2, Ase1_s2_M2
 1138              	    xorrol      r6, r3, r7
 1139              	    str         r6, [r0, #mDa0_s2]
 1140              	    xor5        r6,  Asu1_s2_M2, Agu1_s2_M2, Amu1_s2_M2, Abu0_s2_M2, Aku0_s2_M2
 1141              	    xor5        lr,  Age0_s2_M2, Ame1_s2_M2, Abe1_s2_M2, Ake0_s2_M2, Ase0_s2_M2
 1142              	    eors        r8, r6, lr
 1143              	    str         r8, [r0, #mDa1_s2]
 1144              	
 1145              	    xor5        r5,  Aki1_s2_M2, Asi1_s2_M2, Agi0_s2_M2, Ami1_s2_M2, Abi0_s2_M2
 1146              	    xorrol      r9, r5, r6
 1147              	    str         r9, [r0, #mDo0_s2]
 1148              	    xor5        r4,  Aki0_s2_M2, Asi0_s2_M2, Agi1_s2_M2, Ami0_s2_M2, Abi1_s2_M2
 1149              	    eors        r3, r3, r4
 1150              	    str         r3, [r0, #mDo1_s2]
 1151              	
 1152              	    xor5        r3,  Aba0_s2_M2, Aka1_s2_M2, Asa0_s2_M2, Aga0_s2_M2, Ama1_s2_M2
 1153              	    xorrol      r10, r3, r4
 1154              	    str         r10, [r0, #mDe0_s2]
 1155              	    xor5        r6,  Aba1_s2_M2, Aka0_s2_M2, Asa1_s2_M2, Aga1_s2_M2, Ama0_s2_M2
 1156              	    eors        r11, r6, r5
