 980              	    xor5        r6,  Aba1_s0, Aga1_s0, Aka1_s0, Ama1_s0, Asa1_s0
 981              	    eors        r11, r6, r5
 982              	    str         r11, [r0, #mDe1_s0]
 983              	
 984              	    xor5        r4,  Abo1_s0, Ago1_s0, Ako1_s0, Amo1_s0, Aso1_s0
 985              	    xorrol      r5, lr, r4
 986              	    str         r5, [r0, #mDi0_s0]
 987              	    xor5        r5,  Abo0_s0, Ago0_s0, Ako0_s0, Amo0_s0, Aso0_s0
 988              	    eors        r2, r7, r5
 989              	    str         r2, [r0, #mDi1_s0]
 990              	
 991              	    xorrol      r12, r5, r6
 992              	    str         r12, [r0, #mDu0_s0]
 993              	    eors        lr, r4, r3
 994              	    str         lr, [r0, #mDu1_s0]
 995              	
 996              	    @DIFFUSION SHARE 2
 997              	    xor5        r3,  Abu0_s2, Agu0_s2, Aku0_s2, Amu0_s2, Asu0_s2
 998              	    xor5        r7, Abe1_s2, Age1_s2, Ake1_s2, Ame1_s2, Ase1_s2
 999              	    xorrol      r6, r3, r7
 1000              	    str         r6, [r0, #mDa0_s2]
 1001              	    xor5        r6,  Abu1_s2, Agu1_s2, Aku1_s2, Amu1_s2, Asu1_s2
 1002              	    xor5        lr, Abe0_s2, Age0_s2, Ake0_s2, Ame0_s2, Ase0_s2
 1003              	    eors        r8, r6, lr
 1004              	    str         r8, [r0, #mDa1_s2]
 1005              	
 1006              	    xor5        r5,  Abi0_s2, Agi0_s2, Aki0_s2, Ami0_s2, Asi0_s2
 1007              	    xorrol      r9, r5, r6
 1008              	    str         r9, [r0, #mDo0_s2]
 1009              	    xor5        r4,  Abi1_s2, Agi1_s2, Aki1_s2, Ami1_s2, Asi1_s2
 1010              	    eors        r3, r3, r4
 1011              	    str         r3, [r0, #mDo1_s2]
 1012              	
 1013              	    xor5        r3,  Aba0_s2, Aga0_s2, Aka0_s2, Ama0_s2, Asa0_s2
 1014              	    xorrol      r10, r3, r4
 1015              	    str         r10, [r0, #mDe0_s2]
 1016              	    xor5        r6,  Aba1_s2, Aga1_s2, Aka1_s2, Ama1_s2, Asa1_s2
 1017              	    eors        r11, r6, r5
 1018              	    str         r11, [r0, #mDe1_s2]
 1019              	
 1020              	    xor5        r4,  Abo1_s2, Ago1_s2, Ako1_s2, Amo1_s2, Aso1_s2
 1021              	    xorrol      r5, lr, r4
 1022              	    str         r5, [r0, #mDi0_s2]
 1023              	    xor5        r5,  Abo0_s2, Ago0_s2, Ako0_s2, Amo0_s2, Aso0_s2
 1024              	    eors        r2, r7, r5
 1025              	    str         r2, [r0, #mDi1_s2]
 1026              	
 1027              	    xorrol      r12, r5, r6
 1028              	    str         r12, [r0, #mDu0_s2]
 1029              	    eors        lr, r4, r3
 1030              	    str         lr, [r0, #mDu1_s2]
 1031              	
 1032              	    @DIFFUSION SHARE 1
 1033              	    xor5        r3,  Abu0_s1, Agu0_s1, Aku0_s1, Amu0_s1, Asu0_s1
 1034              	    xor5        r7, Abe1_s1, Age1_s1, Ake1_s1, Ame1_s1, Ase1_s1
 1035              	    xorrol      r6, r3, r7
 1036              	    str         r6, [r0, #mDa0_s1]
 1037              	    xor5        r6,  Abu1_s1, Agu1_s1, Aku1_s1, Amu1_s1, Asu1_s1
 1038              	    xor5        lr, Abe0_s1, Age0_s1, Ake0_s1, Ame0_s1, Ase0_s1
 1039              	    eors        r8, r6, lr
 1040              	    str         r8, [r0, #mDa1_s1]
 1041              	
 1042              	    xor5        r5,  Abi0_s1, Agi0_s1, Aki0_s1, Ami0_s1, Asi0_s1
 1043              	    xorrol      r9, r5, r6
 1044              	    str         r9, [r0, #mDo0_s1]
 1045              	    xor5        r4,  Abi1_s1, Agi1_s1, Aki1_s1, Ami1_s1, Asi1_s1
 1046              	    eors        r3, r3, r4
 1047              	    str         r3, [r0, #mDo1_s1]
 1048              	
 1049              	    xor5        r3,  Aba0_s1, Aga0_s1, Aka0_s1, Ama0_s1, Asa0_s1
 1050              	    xorrol      r10, r3, r4
 1051              	    str         r10, [r0, #mDe0_s1]
 1052              	    xor5        r6,  Aba1_s1, Aga1_s1, Aka1_s1, Ama1_s1, Asa1_s1
 1053              	    eors        r11, r6, r5
 1054              	    str         r11, [r0, #mDe1_s1]
 1055              	
 1056              	    xor5        r4,  Abo1_s1, Ago1_s1, Ako1_s1, Amo1_s1, Aso1_s1
 1057              	    xorrol      r5, lr, r4
 1058              	    str         r5, [r0, #mDi0_s1]
 1059              	    xor5        r5,  Abo0_s1, Ago0_s1, Ako0_s1, Amo0_s1, Aso0_s1
 1060              	    eors        r2, r7, r5
 1061              	    str         r2, [r0, #mDi1_s1]
 1062              	
 1063              	    xorrol      r12, r5, r6
 1064              	    str         r12, [r0, #mDu0_s1]
 1065              	    eors        lr, r4, r3
 1066              	    str         lr, [r0, #mDu1_s1]
 1067              	
 1068              	
 1069              	
 1070              	    KeccakThetaRhoPiChi r5, Aka1_s1, r8,  2, r6, Ame1_s1, r11, 23, r7, Asi1_s1, r2, 31, r3, Abo0_s1
 1071              	    KeccakThetaRhoPiChi r7, Asa1_s1, r8,  9, r3, Abe0_s1, r10,  0, r4, Agi1_s1, r2,  3, r5, Ako0_s1
 1072              	    ldr         r8, [r0, #mDa0_s1]
 1073              	    KeccakThetaRhoPiChi r4, Aga0_s1, r8, 18, r5, Ake0_s1, r10,  5, r6, Ami1_s1, r2,  8, r7, Aso0_s1
 1074              	    KeccakThetaRhoPiChi r6, Ama0_s1, r8, 20, r7, Ase1_s1, r11,  1, r3, Abi1_s1, r2, 31, r4, Ago0_s1
 1075              	    ldr         r9, [r0, #mDo1_s1]
 1076              	    KeccakThetaRhoPiChiIota  Aba0_s1, r8,          Age0_s1, r10, 22,      Aki1_s1, r2, 22,      Amo
 1077              	
 1078              	    ldr         r2, [r0, #mDi0_s1]
 1079              	    KeccakThetaRhoPiChi r5, Aka0_s1, r8,  1, r6, Ame0_s1, r10, 22, r7, Asi0_s1, r2, 30, r3, Abo1_s1
 1080              	    KeccakThetaRhoPiChi r7, Asa0_s1, r8,  9, r3, Abe1_s1, r11,  1, r4, Agi0_s1, r2,  3, r5, Ako1_s1
 1081              	    ldr         r8, [r0, #mDa1_s1]
 1082              	    KeccakThetaRhoPiChi r4, Aga1_s1, r8, 18, r5, Ake1_s1, r11,  5, r6, Ami0_s1, r2,  7, r7, Aso1_s1
 1083              	    KeccakThetaRhoPiChi r6, Ama1_s1, r8, 21, r7, Ase0_s1, r10,  1, r3, Abi0_s1, r2, 31, r4, Ago1_s1
 1084              	    ldr         r9, [r0, #mDo0_s1]
 1085              	    KeccakThetaRhoPiChiIota  Aba1_s1, r8,          Age1_s1, r11, 22,      Aki0_s1, r2, 21,      Amo
 1086              	.endm
