 396              	
 397              	@----------------------------------------------------------------------------------
 398              	@-----------------------------------------XOR5 MACRO-------------------------------
 399              	@----------------------------------------------------------------------------------
 400              	@Used in theta step (at the beginning of each macro KeccakRound0, KeccakRound1, 
 401              	@KeccakRound2, KeccakRound3) to compute the parities C(x) of each column (considering
 402              	@a particular half and share). 
 403              	@
 404              	@It receives as inputs:
 405              	@   -i1, i2, i3, i4, i5: memory addresses where 32-bit lanes from the same column, half, and share
 406              	@                        are stored in the INPUT SPACE
 407              	@   -res: register where the parity value will be stored 
 408              	@
 409              	@This macro XORs all i1, i2, i3, i4, i5 inputs and stores the result in the "res" register
 410              	@
 411              	@Equivalent operation: res <-- i1 XOR i2 XOR i3 XOR i4 XOR i5
 412              	@
 413              	@Intermediate registers: r1, r2, r12
 414              	@----------------------------------------------------------------------------------
 415              	
 416              	
 417              	.macro    xor5      res, i1, i2, i3, i4, i5
 418              	    ldr         \res, [r0, #\i1]
 419              	    ldr         r1, [r0, #\i2]
 420              	    ldr         r2, [r0, #\i3]
 421              	    ldr         r12, [r0, #\i4]
 422              	    eors        \res, \res, r1
 423              	    eors        \res, \res, r2
 424              	    eors        \res, \res, r12
 425              	    ldr         r1, [r0, #\i5]
 426              	    eors        \res, \res, r1
 427              	.endm
 428              	
 429              	@----------------------------------------------------------------------------------
 430              	@----------------------------------------XORROL MACRO------------------------------
 431              	@----------------------------------------------------------------------------------
 432              	@Used in theta step (at the beginning of each macro KeccakRound0, KeccakRound1, 
 433              	@KeccakRound2, KeccakRound3) to compute the diffusions D(x) of low halfs of the lanes
 434              	@in the OUTPUT space.
 435              	@
 436              	@It receives as inputs:
 437              	@   -aa, bb: registers containing the 32-bit half-lanes that will be XORed
 438              	@   -res: register where the resulting 
 439              	@ 
 440              	@This macro XORs the input "aa" with the input "bb" rotated left by 1 bit,
 441              	@and stores it in the "res" register.
 442              	@
 443              	@Equivalent operation: res <-- aa XOR ROTL(bb, 1)
 444              	@
 445              	@Intermediate registers: None
 446              	@----------------------------------------------------------------------------------
 447              	
 448              	.macro    xorrol      res, aa, bb
 449              	    eor         \res, \aa, \bb, ROR #31
 450              	.endm
 451              	
 452              	@----------------------------------------------------------------------------------
 453              	@----------------------------------------OPCHI MACRO-------------------------------
 454              	@----------------------------------------------------------------------------------
 455              	@Used in the macros KeccakThetaRhoPiChi and KeccakThetaRhoPiChiIota to
 456              	@compute the masked Chi function for one given share.
 457              	@
 458              	@For a given row, it computes the share j of the lane i (Y^i_j) at the output of the 
 459              	@Chi step using the 32-bit half-lanes i, i+1, i+2 of the shares j+1, j+2 (X_{j+1}, X_{j+2})
 460              	@
 461              	@It receives as inputs:
 462              	@   -Ia0, Ia1, Ia2: registers containing the 32-bit half-lanes i, i+1, i+2 of the share j+1 (GROUP 
 463              	@   -Ib0, Ib1, Ib2: registers containing the 32-bit half-lanes i, i+1, i+2 of the share j+1 (GROUP 
 464              	@   -memW: memory address where the resulting Y^i_j will be stored
 465              	@
 466              	@Equivalent operation: Y^i_j <-- f(X_{j+1}, X_{j+2}) = 
 467              	@ =X^{i+2}_{j+1} XOR (X^{i+1}_{j+1} & X^{i+2}_{j+1}) XOR (X^{i+1}_{j+1} & X^{i+2}_{j+2}) XOR (X^{i+
 468              	@
 469              	@Intermediate registers: r1, r2
 470              	@----------------------------------------------------------------------------------
 471              	
 472              	.macro    OpChi      memW, Ib0, Ib1, Ib2, Ia0, Ia1, Ia2
 473              	    eors r1, \Ib0, \Ia2
 474              	    and r2, \Ia1, \Ia2
 475              	    eors r1, r1, r2
 476              	    and r2, \Ia1, \Ib2
 477              	    eors r1, r1, r2
 478              	    and r2, \Ib1, \Ia2 
 479              	    eors r1, r1, r2
 480              	    str r1, [r0, \memW]
 481              	.endm
 482              	
 483              	
 484              	@----------------------------------------------------------------------------------
 485              	@----------------------------------KECCAKTHETARHOPICHI MACRO-----------------------
 486              	@----------------------------------------------------------------------------------
 487              	@Used in the macros KeccakRound0, KeccakRound1, KeccakRound2, KeccakRound3 to compute
 488              	@the steps Theta, Rho, Pi Chi.
 489              	@
 490              	@It receives as inputs:
 491              	@   -reg_Aya, reg_Aye, reg_Ayi, reg_Ayo, reg_Ayu: given the diagonal defined for in-place processin
 492              	@   -reg_AyaB, reg_AyeB, reg_AyiB, reg_AyoB, reg_AyuB: given the diagonal defined for in-place proc
 493              	@   -memAya, memAye, memAyi, memAyo, memAyu: given the diagonal defined for in-place processing, me
 494              	@   -Dya, Dye, Dyi, Dyo, Dyu: registers where the diffusion values for each half-lane OF THE SHARE 
 495              	@   -memDya, memDye, memDyi, memDyo, memDyu: memory addresses where the diffusion values for each h
 496              	@   -rotAya, rotAye, rotAyi, rotAyo, rotAyu: rotation values for each half-lane according to rho st
 497              	@
 498              	@Although the group A and group B of registers contains always {r3-r7} and {r8-r12}, respectively, 
 499              	@----------------------------------------------------------------------------------
 500              	.macro    KeccakThetaRhoPiChi reg_Aya, memAya, Dya, rotAya, reg_Aye, memAye, Dye, rotAye, reg_Ayi, 
 501              	    @-----THETA+RHO APPLIED TO S1-------
 502              	    push {r2, r8, r9, r10, r11, r12, lr}
 503              	
 504              	    @Loading the half-lanes of share 1 into the group A registers
 505              	    ldr     \reg_Aya, [r0, #\memAya]
 506              	    ldr     \reg_Aye, [r0, #\memAye]
 507              	    ldr     \reg_Ayi, [r0, #\memAyi]
 508              	    ldr     \reg_Ayo, [r0, #\memAyo]
 509              	    ldr     \reg_Ayu, [r0, #\memAyu]
 510              	
 511              	    @ Applying diffusion values to the lanes of share 1
 512              	    eors    \reg_Aya, \reg_Aya, \Dya
 513              	    eors    \reg_Aye, \reg_Aye, \Dye
 514              	    eors    \reg_Ayi, \reg_Ayi, \Dyi
 515              	    eors    \reg_Ayo, \reg_Ayo, \Dyo
 516              	    eors    \reg_Ayu, \reg_Ayu, \Dyu
 517              	
 518              	    @ Applying rotations of the Rho step to the half-lanes of share 1
 519              	    rors    \reg_Aya, #32-\rotAya
 520              	    .if  \rotAye > 0
 521              	        rors    \reg_Aye, #32-\rotAye
 522              	    .endif
 523              	    rors    \reg_Ayi, #32-\rotAyi
 524              	    rors    \reg_Ayo, #32-\rotAyo
 525              	    rors    \reg_Ayu, #32-\rotAyu
 526              	
 527              	    @ Storing half-lanes of the share 1 after applying Theta+Rho
 528              	    str \reg_Aya, [r0, #\memAya]
 529              	    str \reg_Aye, [r0, #\memAye]
 530              	    str \reg_Ayi, [r0, #\memAyi]
 531              	    str \reg_Ayo, [r0, #\memAyo]
 532              	    str \reg_Ayu, [r0, #\memAyu]
 533              	
 534              	
 535              	
 536              	    @THETA+RHO APPLIED TO S2 
 537              	    @Loading the half-lanes of share 2 into the group B registers 
 538              	    @Loading the diffusion values for the half-lanes of share 2 into the auxiliar registers r1, r2,
 539              	    @Applying diffusion values to the half lanes of share 2
 540              	
 541              	    ldr     \reg_AyaB, [r0, #\memAya+200]
 542              	    ldr     r1, [r0, #\memDya+40]
 543              	    ldr     \reg_AyeB, [r0, #\memAye+200]
 544              	    ldr     r2, [r0, #\memDye+40]
 545              	    ldr     \reg_AyiB, [r0, #\memAyi+200]
 546              	    ldr     lr, [r0, #\memDyi+40]
 547              	
 548              	    eors    \reg_AyaB, \reg_AyaB, r1
 549              	    eors    \reg_AyeB, \reg_AyeB, r2
 550              	    eors    \reg_AyiB, \reg_AyiB, lr
 551              	 
 552              	    ldr     \reg_AyoB, [r0, #\memAyo+200]
 553              	    ldr     r1, [r0, #\memDyo+40]
 554              	    ldr     \reg_AyuB, [r0, #\memAyu+200]
 555              	    ldr     lr, [r0, #\memDyu+40]
 556              	    
 557              	    eors    \reg_AyoB, \reg_AyoB, r1
 558              	    eors    \reg_AyuB, \reg_AyuB, lr   
 559              	    
 560              	
 561              	    @ Applying rotations of the Rho step to the half-lanes of share 2
 562              	    rors    \reg_AyaB, #32-\rotAya
 563              	    .if  \rotAye > 0
 564              	        rors    \reg_AyeB, #32-\rotAye
 565              	    .endif
 566              	    rors    \reg_AyiB, #32-\rotAyi
 567              	    rors    \reg_AyoB, #32-\rotAyo
 568              	    rors    \reg_AyuB, #32-\rotAyu
 569              	
 570              	
 571              	
 572              	    @PI+CHI APPLIED TO SHARE 0 (SHARES 1 - 2). 
 573              	    @At this point, the register values are:
 574              	    @   - r3-r7: half-lanes of the share 1 with Theta and Rho steps applied (Group A)
 575              	    @   - r8-r12: half-lanes of the share 2 with Theta and Rho steps applied (Group B)
 576              	
 577              	    @The following expansions of OpChi macro computes the output share Y_0 from input shares
 578              	    @X_1, X_2 and write them in the corresponding memory address according to in-place processing
 579              	    @(it will be one of the other positions in the diagonal, but not the same)
 580              	    
 581              	    push {r1, r2}
 582              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 583              	    .if     \memAya < 599
 584              	        OpChi   #\memAya+400, r8, r9, r10, r3, r4, r5
 585              	        OpChi   #\memAye+400, r9, r10, r11, r4, r5, r6
 586              	        OpChi   #\memAyi+400, r10, r11, r12, r5, r6, r7
 587              	        OpChi   #\memAyo+400, r11, r12, r8, r6, r7, r3
 588              	        OpChi   #\memAyu+400, r12, r8, r9, r7, r3, r4
 589              	    .else 
 590              	        OpChi   #\memAya-800, r8, r9, r10, r3, r4, r5
 591              	        OpChi   #\memAye-800, r9, r10, r11, r4, r5, r6
 592              	        OpChi   #\memAyi-800, r10, r11, r12, r5, r6, r7
 593              	        OpChi   #\memAyo-800, r11, r12, r8, r6, r7, r3
 594              	        OpChi   #\memAyu-800, r12, r8, r9, r7, r3, r4
 595              	    .endif
 596              	    pop {r1, r2}
 597              	
 598              	
 599              	
 600              	    @THETA+RHO APPLIED TO S0
 601              	
 602              	    @Loading the half-lanes of share 0 into the group A of registers 
 603              	    @Loading the diffusion values for the half-lanes of share 2 into the auxiliar registers r1, r2,
 604              	    @Applying diffusion values to the half lanes of share 2
 605              	
 606              	    ldr     \reg_Aya, [r0, #\memAya-200]
 607              	    ldr     r1, [r0, #\memDya-40]
 608              	    ldr     \reg_Aye, [r0, #\memAye-200]
 609              	    ldr     r2, [r0, #\memDye-40]
 610              	    ldr     \reg_Ayi, [r0, #\memAyi-200]
 611              	    ldr     lr, [r0, #\memDyi-40]
 612              	
 613              	    eors    \reg_Aya, \reg_Aya, r1
 614              	    eors    \reg_Aye, \reg_Aye, r2
 615              	    eors    \reg_Ayi, \reg_Ayi, lr
 616              	
 617              	
 618              	    ldr     \reg_Ayo, [r0, #\memAyo-200]
 619              	    ldr     r1, [r0, #\memDyo-40]
 620              	    ldr     \reg_Ayu, [r0, #\memAyu-200]
 621              	    ldr     lr, [r0, #\memDyu-40]
 622              	    
 623              	    eors    \reg_Ayo, \reg_Ayo, r1
 624              	    eors    \reg_Ayu, \reg_Ayu, lr
 625              	    
 626              	    @ Applying rotations of the Rho step to the half-lanes of share 2
 627              	
 628              	    rors    \reg_Aya, #32-\rotAya
 629              	    .if  \rotAye > 0
 630              	        rors    \reg_Aye, #32-\rotAye
 631              	    .endif
 632              	    rors    \reg_Ayi, #32-\rotAyi
 633              	    rors    \reg_Ayo, #32-\rotAyo
 634              	    rors    \reg_Ayu, #32-\rotAyu
 635              	
 636              	
 637              	
 638              	    @PI+CHI APPLIED TO SHARE 1 (SHARES 2 - 0)
 639              	    @At this point, the register values are:
 640              	    @   - r3-r7: half-lanes of the share 0 with Theta and Rho steps applied (Group A)
 641              	    @   - r8-r12: half-lanes of the share 2 with Theta and Rho steps applied (Group B)
 642              	    @The following expansions of OpChi macro computes the output share Y_1 from input shares
 643              	    @X_2, X_0 and write them in the corresponding memory address according to in-place processing
 644              	    @(it will be one of the other positions in the diagonal, but not the same)
 645              	
 646              	    push {r1, r2}
 647              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 648              	    .if     \memAya < 599
 649              	        OpChi   #\memAya+600, r3, r4, r5, r8, r9, r10
 650              	        OpChi   #\memAye+600, r4, r5, r6, r9, r10, r11
 651              	        OpChi   #\memAyi+600, r5, r6, r7, r10, r11, r12
 652              	        OpChi   #\memAyo+600, r6, r7, r3, r11, r12, r8
 653              	        OpChi   #\memAyu+600, r7, r3, r4, r12, r8, r9
 654              	    .else 
 655              	        OpChi   #\memAya-600, r3, r4, r5, r8, r9, r10
 656              	        OpChi   #\memAye-600, r4, r5, r6, r9, r10, r11
 657              	        OpChi   #\memAyi-600, r5, r6, r7, r10, r11, r12
 658              	        OpChi   #\memAyo-600, r6, r7, r3, r11, r12, r8
 659              	        OpChi   #\memAyu-600, r7, r3, r4, r12, r8, r9
 660              	    .endif
 661              	    pop {r1, r2}
 662              	
 663              	
 664              	    @PI+CHI APPLIED TO SHARE 2 (SHARES 0 - 1). Stack at this point (old --> new): r8-r12: Diffusion
 665              	    
 666              	    @Loading the half-lanes of share 1 (Theta+Rho already applied) into the group B of registers 
 667              	
 668              	    ldr     \reg_AyaB, [r0, #\memAya]             
 669              	    ldr     \reg_AyeB, [r0, #\memAye]         
 670              	    ldr     \reg_AyiB, [r0, #\memAyi]            
 671              	    ldr     \reg_AyoB, [r0, #\memAyo]           
 672              	    ldr     \reg_AyuB, [r0, #\memAyu]           
 673              	
 674              	
 675              	    @At this point, the register values are:
 676              	    @   - r3-r7: half-lanes of the share 0 with Theta and Rho steps applied (Group A)
 677              	    @   - r8-r12: half-lanes of the share 1 with Theta and Rho steps applied (Group B)
 678              	    @The following expansions of OpChi macro computes the output share Y_2 from input shares
 679              	    @X_0, X_1 and write them in the corresponding memory address according to in-place processing
 680              	    @(it will be one of the other positions in the diagonal, but not the same)
 681              	
 682              	    push {r1, r2}
 683              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 684              	    .if     \memAya < 599
 685              	        OpChi   #\memAya+800, r8, r9, r10, r3, r4, r5
 686              	        OpChi   #\memAye+800, r9, r10, r11, r4, r5, r6
 687              	        OpChi   #\memAyi+800, r10, r11, r12, r5, r6, r7
 688              	        OpChi   #\memAyo+800, r11, r12, r8, r6, r7, r3
 689              	        OpChi   #\memAyu+800, r12, r8, r9, r7, r3, r4
 690              	    .else 
 691              	        OpChi   #\memAya-400, r8, r9, r10, r3, r4, r5
 692              	        OpChi   #\memAye-400, r9, r10, r11, r4, r5, r6
 693              	        OpChi   #\memAyi-400, r10, r11, r12, r5, r6, r7
 694              	        OpChi   #\memAyo-400, r11, r12, r8, r6, r7, r3
 695              	        OpChi   #\memAyu-400, r12, r8, r9, r7, r3, r4
 696              	    .endif
 697              	    pop {r1, r2}
 698              	
 699              	
 700              	    pop {r2, r8, r9, r10, r11, r12, lr}
 701              	.endm
 702              	
 703              	
 704              	@----------------------------------------------------------------------------------
 705              	@--------------------------------KECCAKTHETARHOPICHIIOTA MACRO---------------------
 706              	@----------------------------------------------------------------------------------
 707              	@Used in the macros KeccakRound0, KeccakRound1, KeccakRound2, KeccakRound3 to compute
 708              	@the steps Theta, Rho, Pi, Chi, and apply the Round Constant of Iota step to lane Aba (0,0)
 709              	@
 710              	@It receives as inputs:
 711              	@   -memAya, memAye, memAyi, memAyo, memAyu: given the diagonal defined for in-place processing, me
 712              	@   -Dya, Dye, Dyi, Dyo, Dyu: registers where the diffusion values for each half-lane OF THE SHARE 
 713              	@   -rotAya, rotAye, rotAyi, rotAyo, rotAyu: rotation values for each half-lane according to rho st
 714              	@   -memDya, memDye, memDyi, memDyo, memDyu: memory addresses where the diffusion values for each h
 715              	@   -offset: offset applied to access to the round constant of Iota step
 716              	@   -last: flag to indicate if this is the last Iota applied in the fourth cyclic round
 717              	@Registers where lanes will be stores are fixed, due to the fact that this macro processes always t
 718              	@same diagonal (Aba, Age, Aki, Amo, Asu) --> Registers {r3-r7} and {r8-r12} of groups A and B, resp
 719              	
 720              	@----------------------------------------------------------------------------------
 721              	
 722              	.macro    KeccakThetaRhoPiChiIota  memAya, Dya, memAye, Dye, rotAye, memAyi, Dyi, rotAyi, memAyo, D
 723              	    
 724              	    @THETA+RHO APPLIED TO S1
 725              	    push {r2, r8, r9, r10, r11, r12, lr}
 726              	
 727              	    @Loading the half-lanes of share 1 into the group A registers
 728              	    ldr     r3, [r0, #\memAya]
 729              	    ldr     r4, [r0, #\memAye]
 730              	    ldr     r5, [r0, #\memAyi]
 731              	    ldr     r6, [r0, #\memAyo]
 732              	    ldr     r7, [r0, #\memAyu]
 733              	
 734              	    @ Applying diffusion values to the lanes of share 1
 735              	    eors    r3, r3, \Dya
 736              	    eors    r4, r4, \Dye
 737              	    eors    r5, r5, \Dyi
 738              	    eors    r6, r6, \Dyo
 739              	    eors    r7, r7, \Dyu
 740              	
 741              	    @ Applying rotations of the Rho step to the half-lanes of share 1
 742              	    .if  \rotAye > 0
 743              	        rors    r4, #32-\rotAye
 744              	    .endif
 745              	    rors    r5, #32-\rotAyi
 746              	    rors    r6, #32-\rotAyo
 747              	    rors    r7, #32-\rotAyu
 748              	
 749              	    @ Storing half-lanes of the share 1 after applying Theta+Rho
 750              	    str r3, [r0, #\memAya]
 751              	    str r4, [r0, #\memAye]
 752              	    str r5, [r0, #\memAyi]
 753              	    str r6, [r0, #\memAyo]
 754              	    str r7, [r0, #\memAyu]
 755              	
 756              	
 757              	
 758              	    @THETA+RHO APPLIED TO S2 
 759              	    @Loading the half-lanes of share 2 into the group B registers 
 760              	    @Loading the diffusion values for the half-lanes of share 2 into the auxiliar registers r1, r2,
 761              	    @Applying diffusion values to the half lanes of share 2  
 762              	    ldr     r8, [r0, #\memAya+200]
 763              	    ldr     r1, [r0, #\memDya+40]
 764              	    ldr     r9, [r0, #\memAye+200]
 765              	    ldr     r2, [r0, #\memDye+40]
 766              	    ldr     r10, [r0, #\memAyi+200]
 767              	    ldr     lr, [r0, #\memDyi+40]
 768              	
 769              	    eors    r8, r8, r1
 770              	    eors    r9, r9, r2
 771              	    eors    r10, r10, lr
 772              	
 773              	    ldr     r11, [r0, #\memAyo+200]
 774              	    ldr     r1, [r0, #\memDyo+40]
 775              	    ldr     r12, [r0, #\memAyu+200]
 776              	    ldr     lr, [r0, #\memDyu+40]
 777              	    
 778              	    eors    r11, r11, r1
 779              	    eors    r12, r12, lr
 780              	
 781              	    @ Applying rotations of the Rho step to the half-lanes of share 2 
 782              	    .if  \rotAye > 0
 783              	        rors    r9, #32-\rotAye
 784              	    .endif
 785              	    rors    r10, #32-\rotAyi
 786              	    rors    r11, #32-\rotAyo
 787              	    rors    r12, #32-\rotAyu
 788              	
 789              	
 790              	
 791              	
 792              	    @PI+CHI APPLIED TO SHARE 0 (SHARES 1 - 2)
 793              	
 794              	    @At this point, the register values are:
 795              	    @   - r3-r7: half-lanes of the share 1 with Theta and Rho steps applied (Group A)
 796              	    @   - r8-r12: half-lanes of the share 2 with Theta and Rho steps applied (Group B)
 797              	
 798              	    @The following expansions of OpChi macro computes the output share Y_0 from input shares
 799              	    @X_1, X_2 and write them in the corresponding memory address according to in-place processing
 800              	    @(it will be one of the other positions in the diagonal, but not the same)
 801              	
 802              	    push {r1, r2}
 803              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 804              	    .if     \memAya < 599
 805              	        OpChi   #\memAya+400, r8, r9, r10, r3, r4, r5
 806              	        OpChi   #\memAye+400, r9, r10, r11, r4, r5, r6
 807              	        OpChi   #\memAyi+400, r10, r11, r12, r5, r6, r7
 808              	        OpChi   #\memAyo+400, r11, r12, r8, r6, r7, r3
 809              	        OpChi   #\memAyu+400, r12, r8, r9, r7, r3, r4
 810              	    .else 
 811              	        OpChi   #\memAya-800, r8, r9, r10, r3, r4, r5
 812              	        OpChi   #\memAye-800, r9, r10, r11, r4, r5, r6
 813              	        OpChi   #\memAyi-800, r10, r11, r12, r5, r6, r7
 814              	        OpChi   #\memAyo-800, r11, r12, r8, r6, r7, r3
 815              	        OpChi   #\memAyu-800, r12, r8, r9, r7, r3, r4
 816              	    .endif
 817              	    pop {r1, r2}
 818              	
 819              	
 820              	
 821              	
 822              	    @THETA+RHO APPLIED TO S0. Stack at this point (old --> new): r8-r12: Diffusions, r3-r7: SHARE 1
 823              	
 824              	    @Loading the half-lanes of share 0 into the group A of registers 
 825              	    @Loading the diffusion values for the half-lanes of share 2 into the auxiliar registers r1, r2,
 826              	    @Applying diffusion values to the half lanes of share 2
 827              	
 828              	    ldr     r3, [r0, #\memAya-200]
 829              	    ldr     r1, [r0, #\memDya-40]
 830              	    ldr     r4, [r0, #\memAye-200]
 831              	    ldr     r2, [r0, #\memDye-40]
 832              	    ldr     r5, [r0, #\memAyi-200]
 833              	    ldr     lr, [r0, #\memDyi-40]
 834              	
 835              	    eors    r3, r3, r1
 836              	    eors    r4, r4, r2
 837              	    eors    r5, r5, lr
 838              	
 839              	
 840              	    ldr     r6, [r0, #\memAyo-200]
 841              	    ldr     r1, [r0, #\memDyo-40]
 842              	    ldr     r7, [r0, #\memAyu-200]
 843              	    ldr     lr, [r0, #\memDyu-40]
 844              	    
 845              	    eors    r6, r6, r1
 846              	    eors    r7, r7, lr
 847              	
 848              	
 849              	    @ Applying rotations of the Rho step to the half-lanes of share 2
 850              	
 851              	    .if  \rotAye > 0
 852              	        rors    r4, #32-\rotAye
 853              	    .endif
 854              	    rors    r5, #32-\rotAyi
 855              	    rors    r6, #32-\rotAyo
 856              	    rors    r7, #32-\rotAyu
 857              	
 858              	
 859              	
 860              	
 861              	    @PI+CHI APPLIED TO SHARE 1 (SHARES 2 - 0)
 862              	    @At this point, the register values are:
 863              	    @   - r3-r7: half-lanes of the share 0 with Theta and Rho steps applied (Group A)
 864              	    @   - r8-r12: half-lanes of the share 2 with Theta and Rho steps applied (Group B)
 865              	    @The following expansions of OpChi macro computes the output share Y_1 from input shares
 866              	    @X_2, X_0 and write them in the corresponding memory address according to in-place processing
 867              	    @(it will be one of the other positions in the diagonal, but not the same)
 868              	
 869              	    push {r1, r2}
 870              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 871              	    .if     \memAya < 599
 872              	        OpChi   #\memAya+600, r3, r4, r5, r8, r9, r10
 873              	        OpChi   #\memAye+600, r4, r5, r6, r9, r10, r11
 874              	        OpChi   #\memAyi+600, r5, r6, r7, r10, r11, r12
 875              	        OpChi   #\memAyo+600, r6, r7, r3, r11, r12, r8
 876              	        OpChi   #\memAyu+600, r7, r3, r4, r12, r8, r9
 877              	    .else 
 878              	        OpChi   #\memAya-600, r3, r4, r5, r8, r9, r10
 879              	        OpChi   #\memAye-600, r4, r5, r6, r9, r10, r11
 880              	        OpChi   #\memAyi-600, r5, r6, r7, r10, r11, r12
 881              	        OpChi   #\memAyo-600, r6, r7, r3, r11, r12, r8
 882              	        OpChi   #\memAyu-600, r7, r3, r4, r12, r8, r9
 883              	    .endif
 884              	    pop {r1, r2}
 885              	
 886              	
 887              	
 888              	    @PI+CHI APPLIED TO SHARE 2 (SHARES 0 - 1). Stack at this point (old --> new): r8-r12: Diffusion
 889              	    @Loading the half-lanes of share 1 (Theta+Rho already applied) into the group B of registers   
 890              	    ldr     r8, [r0, #\memAya]
 891              	    ldr     r9, [r0, #\memAye]
 892              	    ldr     r10, [r0, #\memAyi]
 893              	    ldr     r11, [r0, #\memAyo]
 894              	    ldr     r12, [r0, #\memAyu]
 895              	
 896              	    push {r1, r2}
 897              	    @If we read from memory zone A, we write in the corresponding memory zone B. Else, we have read
 898              	    .if     \memAya < 599
 899              	        OpChi   #\memAya+800, r8, r9, r10, r3, r4, r5
 900              	        OpChi   #\memAye+800, r9, r10, r11, r4, r5, r6
 901              	        OpChi   #\memAyi+800, r10, r11, r12, r5, r6, r7
 902              	        OpChi   #\memAyo+800, r11, r12, r8, r6, r7, r3
 903              	        OpChi   #\memAyu+800, r12, r8, r9, r7, r3, r4
 904              	    .else 
 905              	        OpChi   #\memAya-400, r8, r9, r10, r3, r4, r5
 906              	        OpChi   #\memAye-400, r9, r10, r11, r4, r5, r6
 907              	        OpChi   #\memAyi-400, r10, r11, r12, r5, r6, r7
 908              	        OpChi   #\memAyo-400, r11, r12, r8, r6, r7, r3
 909              	        OpChi   #\memAyu-400, r12, r8, r9, r7, r3, r4
 910              	    .endif
 911              	    pop {r1, r2}
 912              	
 913              	    @Loading the address where the Round Constants table starts
 914              	    ldr     r1, [r0, #mRC]
 915              	 
 916              	    @IOTA STEP
 917              	
 918              	    @Loading the lane Aba (0,0) into the register r2 (theta+rho+pi+chi steps applied). Read from wr
 919              	    .if     \memAya <599
 920              	        ldr     r2, [r0, #\memAya+800]
 921              	    .else
 922              	        ldr     r2, [r0, #\memAya-400]
 923              	    .endif
 924              	
 925              	    @Loading the Round Constant of Iota step applying the input offset to the memory address where 
 926              	    ldr r4, [r1, #\offset]
 927              	
 928              	    @Lane(0,0) XOR RoundConstant 
 929              	    eors r2, r2, r4
 930              	
 931              	    @Writing-back the lane (0,0) after applying Iota step in the writing memory zone
 932              	    .if     \memAya <599
 933              	        str     r2, [r0, #\memAya+800]
 934              	    .else
 935              	        str     r2, [r0, #\memAya-400]
 936              	    .endif
 937              	
 938              	
 939              	    .if  \last == 1
 940              	        ldr     r4, [r1, #32]!
 941              	        str     r1, [r0, #mRC]
 942              	        cmp     r4, #0xFF
 943              	    .endif
 944              	
 945              	
 946              	
 947              	    pop {r2, r8, r9, r10, r11, r12, lr}
 948              	.endm
 949              	
 950              	
 951              	@----------------------------------------------------------------------------------
 952              	@------------------------------------KECCAKROUND0 MACRO----------------------------
 953              	@----------------------------------------------------------------------------------
 954              	@This macro performs the first cyclic round of Keccak
 955              	@----------------------------------------------------------------------------------
 956              	
 957              	
 958              	.macro    KeccakRound0
 959              	
 960              	    @DIFFUSION SHARE 0
 961              	    xor5        r3,  Abu0_s0, Agu0_s0, Aku0_s0, Amu0_s0, Asu0_s0
 962              	    xor5        r7, Abe1_s0, Age1_s0, Ake1_s0, Ame1_s0, Ase1_s0
 963              	    xorrol      r6, r3, r7
 964              	    str         r6, [r0, #mDa0_s0]
