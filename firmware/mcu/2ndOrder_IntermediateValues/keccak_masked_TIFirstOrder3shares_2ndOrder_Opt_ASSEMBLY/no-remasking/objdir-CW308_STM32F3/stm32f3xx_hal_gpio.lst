 191:../.././hal//stm32f3/stm32f3xx_hal_gpio.c ****       /* In case of Output or Alternate function mode selection */
 192:../.././hal//stm32f3/stm32f3xx_hal_gpio.c ****       if(((GPIO_Init->Mode & GPIO_MODE) == MODE_OUTPUT) || ((GPIO_Init->Mode & GPIO_MODE) == MODE_A
