 194:../.././hal//stm32f3/stm32f3xx_hal_gpio.c ****         /* Check the Speed parameter */
 195:../.././hal//stm32f3/stm32f3xx_hal_gpio.c ****         assert_param(IS_GPIO_SPEED(GPIO_Init->Speed));
 196:../.././hal//stm32f3/stm32f3xx_hal_gpio.c ****         /* Configure the IO Speed */
 197:../.././hal//stm32f3/stm32f3xx_hal_gpio.c ****         temp = GPIOx->OSPEEDR;
 198:../.././hal//stm32f3/stm32f3xx_hal_gpio.c ****         temp &= ~(GPIO_OSPEEDER_OSPEEDR0 << (position * 2u));
