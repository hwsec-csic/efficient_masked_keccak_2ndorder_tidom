  46:KeccakFW.c    **** // ***********************************************************************
  47:KeccakFW.c    **** // ******************************* CHACHA20 ******************************
  48:KeccakFW.c    **** // ***********************************************************************
  49:KeccakFW.c    **** 
  50:KeccakFW.c    **** #define CHACHA20_BLOCK_SIZE 64
  51:KeccakFW.c    **** #define SEED_SIZE 32
  52:KeccakFW.c    **** 
  53:KeccakFW.c    **** int seed_counter = 0;
  54:KeccakFW.c    **** uint32_t prng_state;
  55:KeccakFW.c    **** uint8_t seed_chacha20[32];
  56:KeccakFW.c    **** 
  57:KeccakFW.c    **** typedef struct {
  58:KeccakFW.c    ****     uint32_t state[16];
  59:KeccakFW.c    ****     uint8_t keystream[CHACHA20_BLOCK_SIZE];
  60:KeccakFW.c    ****     int keystream_pos;
  61:KeccakFW.c    **** } chacha20_prng_t;
  62:KeccakFW.c    **** 
  63:KeccakFW.c    **** static chacha20_prng_t prng;
  64:KeccakFW.c    **** static const uint32_t chacha20_constants[4] = {
  65:KeccakFW.c    ****     0x61707865, 0x3320646e, 0x79622d32, 0x6b206574
  66:KeccakFW.c    **** };
  67:KeccakFW.c    **** 
  68:KeccakFW.c    **** #define ROTL(a,b) (((a) << (b)) | ((a) >> (32 - (b))))
  69:KeccakFW.c    **** #define QUARTERROUND(a,b,c,d) \
  70:KeccakFW.c    ****     a += b; d ^= a; d = ROTL(d,16); \
  71:KeccakFW.c    ****     c += d; b ^= c; b = ROTL(b,12); \
  72:KeccakFW.c    ****     a += b; d ^= a; d = ROTL(d,8);  \
  73:KeccakFW.c    ****     c += d; b ^= c; b = ROTL(b,7);
  74:KeccakFW.c    **** 
  75:KeccakFW.c    **** static void chacha20_block(uint32_t out[16], const uint32_t in[16]) {
  76:KeccakFW.c    ****     uint32_t x[16];
  77:KeccakFW.c    ****     memcpy(x, in, sizeof(uint32_t) * 16);
  78:KeccakFW.c    **** 
  79:KeccakFW.c    ****     for (int i = 0; i < 10; i++) {
  80:KeccakFW.c    ****         QUARTERROUND(x[0], x[4], x[8], x[12])
  81:KeccakFW.c    ****         QUARTERROUND(x[1], x[5], x[9], x[13])
  82:KeccakFW.c    ****         QUARTERROUND(x[2], x[6], x[10], x[14])
  83:KeccakFW.c    ****         QUARTERROUND(x[3], x[7], x[11], x[15])
  84:KeccakFW.c    **** 
  85:KeccakFW.c    ****         QUARTERROUND(x[0], x[5], x[10], x[15])
  86:KeccakFW.c    ****         QUARTERROUND(x[1], x[6], x[11], x[12])
  87:KeccakFW.c    ****         QUARTERROUND(x[2], x[7], x[8], x[13])
  88:KeccakFW.c    ****         QUARTERROUND(x[3], x[4], x[9], x[14])
  89:KeccakFW.c    ****     }
  90:KeccakFW.c    **** 
  91:KeccakFW.c    ****     for (int i = 0; i < 16; i++) {
  92:KeccakFW.c    ****         out[i] = x[i] + in[i];
  93:KeccakFW.c    ****     }
  94:KeccakFW.c    **** }
  95:KeccakFW.c    **** 
  96:KeccakFW.c    **** void prng_init(const uint8_t seed[32]) {
  97:KeccakFW.c    ****     prng.state[0] = chacha20_constants[0];
  98:KeccakFW.c    ****     prng.state[1] = chacha20_constants[1];
  99:KeccakFW.c    ****     prng.state[2] = chacha20_constants[2];
 100:KeccakFW.c    ****     prng.state[3] = chacha20_constants[3];
 101:KeccakFW.c    **** 
 102:KeccakFW.c    ****     for (int i = 0; i < 8; i++) {
 103:KeccakFW.c    ****         prng.state[4 + i] =
 104:KeccakFW.c    ****             ((uint32_t)seed[i*4]) |
 105:KeccakFW.c    ****             ((uint32_t)seed[i*4+1] << 8) |
 106:KeccakFW.c    ****             ((uint32_t)seed[i*4+2] << 16) |
 107:KeccakFW.c    ****             ((uint32_t)seed[i*4+3] << 24);
 108:KeccakFW.c    ****     }
 109:KeccakFW.c    **** 
 110:KeccakFW.c    ****     prng.state[12] = 0; // counter
 111:KeccakFW.c    ****     prng.state[13] = 0; prng.state[14] = 0; prng.state[15] = 0; // nonce
 112:KeccakFW.c    **** 
 113:KeccakFW.c    ****     prng.keystream_pos = CHACHA20_BLOCK_SIZE;
 114:KeccakFW.c    **** }
 115:KeccakFW.c    **** 
 116:KeccakFW.c    **** static void prng_generate_block() {
 117:KeccakFW.c    ****     chacha20_block((uint32_t*)prng.keystream, prng.state);
 118:KeccakFW.c    ****     prng.state[12]++;
 119:KeccakFW.c    ****     prng.keystream_pos = 0;
 120:KeccakFW.c    **** }
 121:KeccakFW.c    **** 
 122:KeccakFW.c    **** uint8_t prng_get_byte() {
 123:KeccakFW.c    ****     if (prng.keystream_pos >= CHACHA20_BLOCK_SIZE) {
 124:KeccakFW.c    ****         prng_generate_block();
 125:KeccakFW.c    ****     }
 126:KeccakFW.c    ****     return prng.keystream[prng.keystream_pos++];
 127:KeccakFW.c    **** }
 128:KeccakFW.c    **** 
 129:KeccakFW.c    **** uint64_t rand_share_64() {
 130:KeccakFW.c    ****     uint64_t r = 0;
 131:KeccakFW.c    ****     for (int i = 0; i < 8; i++) {
 132:KeccakFW.c    ****         r |= ((uint64_t)prng_get_byte()) << (8 * i);
 133:KeccakFW.c    ****     }
 134:KeccakFW.c    ****     return r;
 135:KeccakFW.c    **** }
