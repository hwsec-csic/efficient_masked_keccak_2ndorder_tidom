 208:KeccakFW.c    **** uint8_t get_seed(uint8_t* seed, uint8_t len)
 209:KeccakFW.c    **** {
 210:KeccakFW.c    ****     int i;
 211:KeccakFW.c    ****     for(i=0; i<16; i++)
 212:KeccakFW.c    ****     {
 213:KeccakFW.c    ****         seed_chacha20[i+(seed_counter*16)] = seed[i]; 
 214:KeccakFW.c    ****     }
 215:KeccakFW.c    ****     seed_counter = (seed_counter + 1) % 2;
 216:KeccakFW.c    ****     if(seed_counter == 0)
 217:KeccakFW.c    ****     {
 218:KeccakFW.c    ****         prng_init(seed_chacha20);
 219:KeccakFW.c    ****     }
 220:KeccakFW.c    ****     simpleserial_put('r', 16, seed);
 221:KeccakFW.c    ****     return 0x00;
 222:KeccakFW.c    **** }
