 139:KeccakFW.c    **** // *****************************  BIT INTERLEAVING ***************************
 140:KeccakFW.c    **** // ***************************************************************************
 141:KeccakFW.c    **** void bit_interleave(const uint8_t s0[200], uint8_t I0[200]) {
 142:KeccakFW.c    ****     for (int blk = 0; blk < 200; blk += 8) {
 143:KeccakFW.c    ****         uint64_t word = 0;
 144:KeccakFW.c    ****         for (int j = 0; j < 8; j++) {
 145:KeccakFW.c    ****             word |= ((uint64_t)s0[blk + j]) << (8 * j);
 146:KeccakFW.c    ****         }
 147:KeccakFW.c    **** 
 148:KeccakFW.c    ****         uint8_t h[8] = {0};
 149:KeccakFW.c    **** 
 150:KeccakFW.c    ****         for (int bit = 0; bit < 64; bit++) {
 151:KeccakFW.c    ****             int byte_out, bit_out;
 152:KeccakFW.c    ****             uint8_t bitval = (word >> bit) & 1;
 153:KeccakFW.c    **** 
 154:KeccakFW.c    ****             if ((bit / 16) < 4) { 
 155:KeccakFW.c    ****                 if ((bit % 2) == 0)
 156:KeccakFW.c    ****                     byte_out = (bit / 16);      
 157:KeccakFW.c    ****                 else
 158:KeccakFW.c    ****                     byte_out = 4 + (bit / 16);  
 159:KeccakFW.c    ****                 bit_out = (bit % 16) / 2;
 160:KeccakFW.c    ****             } else {
 161:KeccakFW.c    ****                 continue; 
 162:KeccakFW.c    ****             }
 163:KeccakFW.c    **** 
 164:KeccakFW.c    ****             h[byte_out] |= bitval << bit_out;
 165:KeccakFW.c    ****         }
 166:KeccakFW.c    **** 
 167:KeccakFW.c    ****         for (int i = 0; i < 8; i++) {
 168:KeccakFW.c    ****             I0[blk + i] = h[i];
 169:KeccakFW.c    ****         }
 170:KeccakFW.c    ****     }
 171:KeccakFW.c    **** }
 172:KeccakFW.c    **** 
 173:KeccakFW.c    **** 
 174:KeccakFW.c    **** void bit_deinterleave(const uint8_t I0[200], uint8_t s0[200]) {
 175:KeccakFW.c    ****     for (int blk = 0; blk < 200; blk += 8) {
 176:KeccakFW.c    ****         uint64_t word = 0;
 177:KeccakFW.c    **** 
 178:KeccakFW.c    ****         for (int group = 0; group < 4; group++) {
 179:KeccakFW.c    ****             uint8_t even = I0[blk + group];     
 180:KeccakFW.c    ****             uint8_t odd  = I0[blk + 4 + group];  
 181:KeccakFW.c    **** 
 182:KeccakFW.c    ****             for (int k = 0; k < 8; k++) {
 183:KeccakFW.c    ****                 uint8_t bit_even = (even >> k) & 1;
 184:KeccakFW.c    ****                 uint8_t bit_odd  = (odd  >> k) & 1;
 185:KeccakFW.c    **** 
 186:KeccakFW.c    ****                 int base = group * 16;
 187:KeccakFW.c    **** 
 188:KeccakFW.c    ****                 word |= ((uint64_t)bit_even) << (base + 2 * k);
 189:KeccakFW.c    ****                 word |= ((uint64_t)bit_odd)  << (base + 2 * k + 1);
 190:KeccakFW.c    ****             }
 191:KeccakFW.c    ****         }
 192:KeccakFW.c    **** 
 193:KeccakFW.c    ****         for (int j = 0; j < 8; j++) {
 194:KeccakFW.c    ****             s0[blk + j] = (word >> (8 * j)) & 0xFF;
 195:KeccakFW.c    ****         }
 196:KeccakFW.c    ****     }
 197:KeccakFW.c    **** }
