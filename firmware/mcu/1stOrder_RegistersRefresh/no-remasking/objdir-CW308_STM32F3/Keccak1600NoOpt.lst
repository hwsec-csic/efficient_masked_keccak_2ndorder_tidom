 356              	.macro    xor5      res, i1, i2, i3, i4, i5
 357              	    ldr         \res, [r0, #\i1]
 358              	    ldr         r1, [r0, #\i2]
 359              	    ldr         r2, [r0, #\i3]
 360              	    ldr         r12, [r0, #\i4]
 361              	    eors        \res, \res, r1
 362              	    eors        \res, \res, r2
 363              	    eors        \res, \res, r12
 364              	    ldr         r1, [r0, #\i5]
 365              	    eors        \res, \res, r1
 366              	.endm
 367              	
 368              	.macro    xorrol      res, aa, bb
 369              	    eor         \res, \aa, \bb, ROR #31
 370              	.endm
 371              	
 372              	.macro    OpChi      memW, Ib1, Ib2, Ia0, Ia1, Ia2
 373              	    eors r1, \Ia0, \Ia2
 374              	    and r2, \Ia1, \Ia2
 375              	    eors r1, r1, r2
 376              	    and r2, \Ia1, \Ib2
 377              	    eors r1, r1, r2
 378              	    and r2, \Ib1, \Ia2 
 379              	    eors r1, r1, r2
 380              	    str r1, [r0, \memW]
 381              	.endm
 382              	
 383              	
 384              	
 385              	.macro    KeccakThetaRhoPiChi reg_Aya, memAya, Dya, rotAya, reg_Aye, memAye, Dye, rotAye, reg_Ayi, 
 386              	    @THETA+RHO APPLIED TO S1
 387              	    push {r2, r8, r9, r10, r11, r12, lr}
 388              	
 389              	    ldr     \reg_Aya, [r0, #\memAya]
 390              	    ldr     \reg_Aye, [r0, #\memAye]
 391              	    ldr     \reg_Ayi, [r0, #\memAyi]
 392              	    ldr     \reg_Ayo, [r0, #\memAyo]
 393              	    ldr     \reg_Ayu, [r0, #\memAyu]
 394              	
 395              	
 396              	    eors    \reg_Aya, \reg_Aya, \Dya
 397              	    eors    \reg_Aye, \reg_Aye, \Dye
 398              	    eors    \reg_Ayi, \reg_Ayi, \Dyi
 399              	    eors    \reg_Ayo, \reg_Ayo, \Dyo
 400              	    eors    \reg_Ayu, \reg_Ayu, \Dyu
 401              	
 402              	    rors    \reg_Aya, #32-\rotAya
 403              	    .if  \rotAye > 0
 404              	        rors    \reg_Aye, #32-\rotAye
 405              	    .endif
 406              	    rors    \reg_Ayi, #32-\rotAyi
 407              	    rors    \reg_Ayo, #32-\rotAyo
 408              	    rors    \reg_Ayu, #32-\rotAyu
 409              	
 410              	
