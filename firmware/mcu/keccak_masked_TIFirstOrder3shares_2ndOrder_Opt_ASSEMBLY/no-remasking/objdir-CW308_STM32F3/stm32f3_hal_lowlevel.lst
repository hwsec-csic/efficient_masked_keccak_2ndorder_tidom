 791:../.././hal//stm32f3/stm32f3_hal_lowlevel.c **** /**
 792:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   * @brief Check the UART Idle State.
 793:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   * @param huart UART handle.
 794:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   * @retval HAL status
 795:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   */
 796:../.././hal//stm32f3/stm32f3_hal_lowlevel.c **** HAL_StatusTypeDef UART_CheckIdleState(UART_HandleTypeDef *huart)
 797:../.././hal//stm32f3/stm32f3_hal_lowlevel.c **** {
 798:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   uint32_t tickstart = 0U;
 799:../.././hal//stm32f3/stm32f3_hal_lowlevel.c **** 
 800:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   /* Initialize the UART ErrorCode */
 801:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   huart->ErrorCode = HAL_UART_ERROR_NONE;
 802:../.././hal//stm32f3/stm32f3_hal_lowlevel.c **** 
 803:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   /* Init tickstart for timeout managment*/
 804:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   tickstart = HAL_GetTick();
 805:../.././hal//stm32f3/stm32f3_hal_lowlevel.c **** 
 806:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   /* Check if the Transmitter is enabled */
 807:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   if((huart->Instance->CR1 & USART_CR1_TE) == USART_CR1_TE)
 808:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   {
 809:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****     /* Wait until TEACK flag is set */
 810:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****     if(UART_WaitOnFlagUntilTimeout(huart, USART_ISR_TEACK, RESET, tickstart, HAL_UART_TIMEOUT_VALUE
 811:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****     {
 812:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****       /* Timeout Occured */
 813:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****       return HAL_TIMEOUT;
 814:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****     }
 815:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   }
 816:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   /* Check if the Receiver is enabled */
 817:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   if((huart->Instance->CR1 & USART_CR1_RE) == USART_CR1_RE)
 818:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   {
 819:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****     /* Wait until REACK flag is set */
 820:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****     if(UART_WaitOnFlagUntilTimeout(huart, USART_ISR_REACK, RESET, tickstart, HAL_UART_TIMEOUT_VALUE
 821:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****     {
 822:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****       /* Timeout Occured */
 823:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****       return HAL_TIMEOUT;
 824:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****     }
 825:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   }
 826:../.././hal//stm32f3/stm32f3_hal_lowlevel.c **** 
 827:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   /* Initialize the UART State */
 828:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   huart->gState  = HAL_UART_STATE_READY;
 829:../.././hal//stm32f3/stm32f3_hal_lowlevel.c ****   huart->RxState = HAL_UART_STATE_READY;
 830:../.././hal//stm32f3/stm32f3_hal_lowlevel.c **** 
