 196:KeccakFW.c    **** uint8_t get_seed(uint8_t* seed, uint8_t len)
 197:KeccakFW.c    **** {
 198:KeccakFW.c    ****     int i;
 199:KeccakFW.c    ****     for(i=0; i<16; i++)
 200:KeccakFW.c    ****     {
 201:KeccakFW.c    ****         seed_chacha20[i+(seed_counter*16)] = seed[i]; 
 202:KeccakFW.c    ****     }
 203:KeccakFW.c    ****     seed_counter = (seed_counter + 1) % 2;
 204:KeccakFW.c    ****     if(seed_counter == 0)
 205:KeccakFW.c    ****     {
 206:KeccakFW.c    ****         prng_init(seed_chacha20);
 207:KeccakFW.c    ****     }
 208:KeccakFW.c    ****     simpleserial_put('r', 16, seed);
 209:KeccakFW.c    ****     return 0x00;
 210:KeccakFW.c    **** }
