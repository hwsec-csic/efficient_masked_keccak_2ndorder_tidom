 246:KeccakFW.c    ****     bit_deinterleave(I0, s0);
 247:KeccakFW.c    ****     for(i=0;i<25;i++)
 248:KeccakFW.c    ****     {
 249:KeccakFW.c    ****         for(j=0;j<8;j++)
 250:KeccakFW.c    ****         {
 251:KeccakFW.c    ****             bytes_st[i][j] = s0[0+8*i+j];
 252:KeccakFW.c    ****         }
 253:KeccakFW.c    ****     }
 254:KeccakFW.c    **** 
 255:KeccakFW.c    ****     i=(int)lane[0];
 256:KeccakFW.c    ****     for(j=0;j<8;j++)
 257:KeccakFW.c    ****     {
 258:KeccakFW.c    ****         bytes_st_msg[j] = bytes_st[i][j];
 259:KeccakFW.c    ****     }    
 260:KeccakFW.c    **** 
 261:KeccakFW.c    ****     simpleserial_put('m', 8, bytes_st_msg);
 262:KeccakFW.c    **** 	return 0x00;
 263:KeccakFW.c    **** }
