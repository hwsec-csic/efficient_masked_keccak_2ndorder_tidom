 220:KeccakFW.c    **** uint8_t get_pt(uint8_t* pt, uint8_t len)
 221:KeccakFW.c    **** {   
 222:KeccakFW.c    ****     int i;
 223:KeccakFW.c    ****     create_state(pt, len);
 224:KeccakFW.c    ****     // mask_state();
 225:KeccakFW.c    ****     bit_interleave(s0, I0);
 226:KeccakFW.c    ****     *SCB_DEMCR |= 0x01000000;
 227:KeccakFW.c    ****     *DWT_CYCCNT = 0; // reset the counter
 228:KeccakFW.c    ****     *DWT_CONTROL |= 1 ; // enable the counter
 229:KeccakFW.c    ****     x = *DWT_CYCCNT;
 230:KeccakFW.c    ****     trigger_high();
 231:KeccakFW.c    ****     KeccakF1600_StatePermute(I0);
 232:KeccakFW.c    ****     trigger_low();
 233:KeccakFW.c    ****     y = *DWT_CYCCNT;
 234:KeccakFW.c    ****     delta = (y - x);
 235:KeccakFW.c    **** 	simpleserial_put('r', 16, pt);
 236:KeccakFW.c    **** 	return 0x00;
 237:KeccakFW.c    **** }
