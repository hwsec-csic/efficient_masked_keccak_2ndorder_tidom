 126:KeccakFW.c    **** // ***************************************************************************
 127:KeccakFW.c    **** // *****************************  BIT INTERLEAVING ***************************
 128:KeccakFW.c    **** // ***************************************************************************
 129:KeccakFW.c    **** void bit_interleave(const uint8_t s0[200], uint8_t I0[200]) {
 130:KeccakFW.c    ****     for (int blk = 0; blk < 200; blk += 8) {
 131:KeccakFW.c    ****         uint64_t word = 0;
 132:KeccakFW.c    ****         for (int j = 0; j < 8; j++) {
 133:KeccakFW.c    ****             word |= ((uint64_t)s0[blk + j]) << (8 * j);
 134:KeccakFW.c    ****         }
 135:KeccakFW.c    **** 
 136:KeccakFW.c    ****         uint8_t h[8] = {0};
 137:KeccakFW.c    **** 
 138:KeccakFW.c    ****         for (int bit = 0; bit < 64; bit++) {
 139:KeccakFW.c    ****             int byte_out, bit_out;
 140:KeccakFW.c    ****             uint8_t bitval = (word >> bit) & 1;
 141:KeccakFW.c    **** 
 142:KeccakFW.c    ****             if ((bit / 16) < 4) { 
 143:KeccakFW.c    ****                 if ((bit % 2) == 0)
 144:KeccakFW.c    ****                     byte_out = (bit / 16);      
 145:KeccakFW.c    ****                 else
 146:KeccakFW.c    ****                     byte_out = 4 + (bit / 16);  
 147:KeccakFW.c    ****                 bit_out = (bit % 16) / 2;
 148:KeccakFW.c    ****             } else {
 149:KeccakFW.c    ****                 continue; 
 150:KeccakFW.c    ****             }
 151:KeccakFW.c    **** 
 152:KeccakFW.c    ****             h[byte_out] |= bitval << bit_out;
 153:KeccakFW.c    ****         }
 154:KeccakFW.c    **** 
 155:KeccakFW.c    ****         for (int i = 0; i < 8; i++) {
 156:KeccakFW.c    ****             I0[blk + i] = h[i];
 157:KeccakFW.c    ****         }
 158:KeccakFW.c    ****     }
 159:KeccakFW.c    **** }
 160:KeccakFW.c    **** 
 161:KeccakFW.c    **** 
 162:KeccakFW.c    **** void bit_deinterleave(const uint8_t I0[200], uint8_t s0[200]) {
 163:KeccakFW.c    ****     for (int blk = 0; blk < 200; blk += 8) {
 164:KeccakFW.c    ****         uint64_t word = 0;
 165:KeccakFW.c    **** 
 166:KeccakFW.c    ****         for (int group = 0; group < 4; group++) {
 167:KeccakFW.c    ****             uint8_t even = I0[blk + group];     
 168:KeccakFW.c    ****             uint8_t odd  = I0[blk + 4 + group];  
 169:KeccakFW.c    **** 
 170:KeccakFW.c    ****             for (int k = 0; k < 8; k++) {
 171:KeccakFW.c    ****                 uint8_t bit_even = (even >> k) & 1;
 172:KeccakFW.c    ****                 uint8_t bit_odd  = (odd  >> k) & 1;
 173:KeccakFW.c    **** 
 174:KeccakFW.c    ****                 int base = group * 16;
 175:KeccakFW.c    **** 
 176:KeccakFW.c    ****                 word |= ((uint64_t)bit_even) << (base + 2 * k);
 177:KeccakFW.c    ****                 word |= ((uint64_t)bit_odd)  << (base + 2 * k + 1);
 178:KeccakFW.c    ****             }
 179:KeccakFW.c    ****         }
 180:KeccakFW.c    **** 
 181:KeccakFW.c    ****         for (int j = 0; j < 8; j++) {
 182:KeccakFW.c    ****             s0[blk + j] = (word >> (8 * j)) & 0xFF;
 183:KeccakFW.c    ****         }
 184:KeccakFW.c    ****     }
 185:KeccakFW.c    **** }
