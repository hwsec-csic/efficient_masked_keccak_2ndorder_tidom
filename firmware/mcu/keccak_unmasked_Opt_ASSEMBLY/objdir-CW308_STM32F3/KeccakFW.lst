  34:KeccakFW.c    **** // ***********************************************************************
  35:KeccakFW.c    **** // ******************************* CHACHA20 ******************************
  36:KeccakFW.c    **** // ***********************************************************************
  37:KeccakFW.c    **** 
  38:KeccakFW.c    **** #define CHACHA20_BLOCK_SIZE 64
  39:KeccakFW.c    **** #define SEED_SIZE 32
  40:KeccakFW.c    **** 
  41:KeccakFW.c    **** int seed_counter = 0;
  42:KeccakFW.c    **** uint32_t prng_state;
  43:KeccakFW.c    **** uint8_t seed_chacha20[32];
  44:KeccakFW.c    **** 
  45:KeccakFW.c    **** typedef struct {
  46:KeccakFW.c    ****     uint32_t state[16];
  47:KeccakFW.c    ****     uint8_t keystream[CHACHA20_BLOCK_SIZE];
  48:KeccakFW.c    ****     int keystream_pos;
  49:KeccakFW.c    **** } chacha20_prng_t;
  50:KeccakFW.c    **** 
  51:KeccakFW.c    **** static chacha20_prng_t prng;
  52:KeccakFW.c    **** static const uint32_t chacha20_constants[4] = {
  53:KeccakFW.c    ****     0x61707865, 0x3320646e, 0x79622d32, 0x6b206574
  54:KeccakFW.c    **** };
  55:KeccakFW.c    **** 
  56:KeccakFW.c    **** #define ROTL(a,b) (((a) << (b)) | ((a) >> (32 - (b))))
  57:KeccakFW.c    **** #define QUARTERROUND(a,b,c,d) \
  58:KeccakFW.c    ****     a += b; d ^= a; d = ROTL(d,16); \
  59:KeccakFW.c    ****     c += d; b ^= c; b = ROTL(b,12); \
  60:KeccakFW.c    ****     a += b; d ^= a; d = ROTL(d,8);  \
  61:KeccakFW.c    ****     c += d; b ^= c; b = ROTL(b,7);
  62:KeccakFW.c    **** 
  63:KeccakFW.c    **** static void chacha20_block(uint32_t out[16], const uint32_t in[16]) {
  64:KeccakFW.c    ****     uint32_t x[16];
  65:KeccakFW.c    ****     memcpy(x, in, sizeof(uint32_t) * 16);
  66:KeccakFW.c    **** 
  67:KeccakFW.c    ****     for (int i = 0; i < 10; i++) {
  68:KeccakFW.c    ****         QUARTERROUND(x[0], x[4], x[8], x[12])
  69:KeccakFW.c    ****         QUARTERROUND(x[1], x[5], x[9], x[13])
  70:KeccakFW.c    ****         QUARTERROUND(x[2], x[6], x[10], x[14])
  71:KeccakFW.c    ****         QUARTERROUND(x[3], x[7], x[11], x[15])
  72:KeccakFW.c    **** 
  73:KeccakFW.c    ****         QUARTERROUND(x[0], x[5], x[10], x[15])
  74:KeccakFW.c    ****         QUARTERROUND(x[1], x[6], x[11], x[12])
  75:KeccakFW.c    ****         QUARTERROUND(x[2], x[7], x[8], x[13])
  76:KeccakFW.c    ****         QUARTERROUND(x[3], x[4], x[9], x[14])
  77:KeccakFW.c    ****     }
  78:KeccakFW.c    **** 
  79:KeccakFW.c    ****     for (int i = 0; i < 16; i++) {
  80:KeccakFW.c    ****         out[i] = x[i] + in[i];
  81:KeccakFW.c    ****     }
  82:KeccakFW.c    **** }
  83:KeccakFW.c    **** 
  84:KeccakFW.c    **** void prng_init(const uint8_t seed[32]) {
  85:KeccakFW.c    ****     prng.state[0] = chacha20_constants[0];
  86:KeccakFW.c    ****     prng.state[1] = chacha20_constants[1];
  87:KeccakFW.c    ****     prng.state[2] = chacha20_constants[2];
  88:KeccakFW.c    ****     prng.state[3] = chacha20_constants[3];
  89:KeccakFW.c    **** 
  90:KeccakFW.c    ****     for (int i = 0; i < 8; i++) {
  91:KeccakFW.c    ****         prng.state[4 + i] =
  92:KeccakFW.c    ****             ((uint32_t)seed[i*4]) |
  93:KeccakFW.c    ****             ((uint32_t)seed[i*4+1] << 8) |
  94:KeccakFW.c    ****             ((uint32_t)seed[i*4+2] << 16) |
  95:KeccakFW.c    ****             ((uint32_t)seed[i*4+3] << 24);
  96:KeccakFW.c    ****     }
  97:KeccakFW.c    **** 
  98:KeccakFW.c    ****     prng.state[12] = 0; // counter
  99:KeccakFW.c    ****     prng.state[13] = 0; prng.state[14] = 0; prng.state[15] = 0; // nonce
 100:KeccakFW.c    **** 
 101:KeccakFW.c    ****     prng.keystream_pos = CHACHA20_BLOCK_SIZE;
 102:KeccakFW.c    **** }
 103:KeccakFW.c    **** 
 104:KeccakFW.c    **** static void prng_generate_block() {
 105:KeccakFW.c    ****     chacha20_block((uint32_t*)prng.keystream, prng.state);
 106:KeccakFW.c    ****     prng.state[12]++;
 107:KeccakFW.c    ****     prng.keystream_pos = 0;
 108:KeccakFW.c    **** }
 109:KeccakFW.c    **** 
 110:KeccakFW.c    **** uint8_t prng_get_byte() {
 111:KeccakFW.c    ****     if (prng.keystream_pos >= CHACHA20_BLOCK_SIZE) {
 112:KeccakFW.c    ****         prng_generate_block();
 113:KeccakFW.c    ****     }
 114:KeccakFW.c    ****     return prng.keystream[prng.keystream_pos++];
 115:KeccakFW.c    **** }
 116:KeccakFW.c    **** 
 117:KeccakFW.c    **** uint64_t rand_share_64() {
 118:KeccakFW.c    ****     uint64_t r = 0;
 119:KeccakFW.c    ****     for (int i = 0; i < 8; i++) {
 120:KeccakFW.c    ****         r |= ((uint64_t)prng_get_byte()) << (8 * i);
 121:KeccakFW.c    ****     }
 122:KeccakFW.c    ****     return r;
 123:KeccakFW.c    **** }
