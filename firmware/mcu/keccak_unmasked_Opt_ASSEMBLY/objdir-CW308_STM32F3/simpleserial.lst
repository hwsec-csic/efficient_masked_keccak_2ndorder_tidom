 257:.././simpleserial/simpleserial.c **** 	uint8_t flags;
 258:.././simpleserial/simpleserial.c **** } ss_cmd;
 259:.././simpleserial/simpleserial.c **** static ss_cmd commands[MAX_SS_CMDS];
